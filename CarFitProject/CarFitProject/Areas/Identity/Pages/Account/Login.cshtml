@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="glass-card shadow-lg bg-white rounded-4 p-5">
                <div class="text-center mb-4">
                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary px-3 py-2 rounded-pill fw-bold mb-3">SECURITY CONTROL ENTRY</span>
                    <h2 class="fw-bold text-dark mb-1">Welcome Back</h2>
                    <p class="text-muted">Sign in to your CarFit driver or dealership profile account.</p>
                </div>

                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>
                    
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control border-2" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                        <label asp-for="Input.Email" class="fw-bold text-secondary">Email Address</label>
                        <span asp-validation-for="Input.Email" class="text-danger small mt-1 d-block"></span>
                    </div>
                    
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" class="form-control border-2" autocomplete="current-password" aria-required="true" placeholder="password" />
                        <label asp-for="Input.Password" class="fw-bold text-secondary">Password</label>
                        <span asp-validation-for="Input.Password" class="text-danger small mt-1 d-block"></span>
                    </div>
                    
                    <div class="form-check mb-4 text-start">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label asp-for="Input.RememberMe" class="form-check-label text-secondary small fw-bold">
                            @Html.DisplayNameFor(m => m.Input.RememberMe)
                        </label>
                    </div>

                    <div class="mb-4">
                        <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary py-3 fw-bold"><i class="fa-solid fa-right-to-bracket me-2"></i>Sign In</button>
                    </div>

                    <div class="text-center border-top pt-3">
                        <p class="mb-1">
                            <a id="forgot-password" asp-page="./ForgotPassword" class="text-decoration-none text-secondary small fw-bold">Forgot your password?</a>
                        </p>
                        <p class="mb-0">
                            <span class="text-muted small">Don't have an account?</span> 
                            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-decoration-none text-primary small fw-bold">Register here</a>
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
