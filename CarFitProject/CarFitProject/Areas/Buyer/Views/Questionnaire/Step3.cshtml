@model CarFitProject.ViewModel.QuestionnaireStep3ViewModel
@{
    ViewData["Title"] = L["Wizard.Step3.Title"].Value;
    ViewData["WizardStep"] = 3;
    var purposes = new (string Value, string Key)[]
    {
        ("Work", "Field.Purpose.Work"),
        ("University", "Field.Purpose.University"),
        ("Family use", "Field.Purpose.Family"),
        ("Travel", "Field.Purpose.Travel")
    };
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <partial name="_WizardProgress" />
            <div class="form-section-card">
                <div class="section-heading">
                    <h2>@L["Wizard.Step3.Title"]</h2>
                </div>
                <p class="text-muted mb-4">@L["Wizard.Step3.Subtitle"]</p>

                <form method="post" asp-action="Step3" novalidate>
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                    <div class="mb-3">
                        <label class="fw-bold text-secondary d-block mb-2" asp-for="Purpose"></label>
                        <select asp-for="Purpose" class="form-select border-2">
                            @foreach (var (value, key) in purposes)
                            {
                                <option value="@value">@L[key]</option>
                            }
                        </select>
                        <span asp-validation-for="Purpose" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-4">
                        <label class="cf-field-label d-block mb-2">@L["Field.TripType"]</label>
                        <div class="row g-3" role="group" aria-label="@L["Field.TripType"]">
                            <div class="col-sm-6">
                                <input asp-for="TripType" type="radio" class="option-input" id="trip-short" value="Short" autocomplete="off" />
                                <label for="trip-short" class="option-card">
                                    <div class="option-icon"><i class="fa-solid fa-city"></i></div>
                                    <div class="option-title">@L["Field.TripShort"]</div>
                                    <div class="option-sub">City &amp; nearby</div>
                                </label>
                            </div>
                            <div class="col-sm-6">
                                <input asp-for="TripType" type="radio" class="option-input" id="trip-long" value="Long" autocomplete="off" />
                                <label for="trip-long" class="option-card">
                                    <div class="option-icon"><i class="fa-solid fa-road"></i></div>
                                    <div class="option-title">@L["Field.TripLong"]</div>
                                    <div class="option-sub">Highways &amp; travel</div>
                                </label>
                            </div>
                        </div>
                        <span asp-validation-for="TripType" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="sticky-cta mt-4 justify-content-between">
                        <button type="submit" name="action" value="back" formnovalidate class="btn btn-outline-secondary fw-bold">
                            <i class="fa fa-arrow-left me-2"></i>@L["Action.Back"]
                        </button>
                        <button type="submit" name="action" value="next" class="btn btn-primary fw-bold">
                            @L["Action.Next"]<i class="fa fa-arrow-right ms-2"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
