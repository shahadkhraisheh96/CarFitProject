@model CarFitProject.ViewModel.QuestionnaireStep5ViewModel
@{
    ViewData["Title"] = L["Wizard.Step5.Title"].Value;
    ViewData["WizardStep"] = 5;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <partial name="_WizardProgress" />
            <div class="form-section-card">
                <div class="section-heading">
                    <h2>@L["Wizard.Step5.Title"]</h2>
                </div>
                <p class="text-muted mb-4">@L["Wizard.Step5.Subtitle"]</p>

                <form method="post" asp-action="Step5" novalidate>
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                    <div class="mb-4">
                        <label class="cf-field-label d-block mb-2">@L["Field.Condition"]</label>
                        <div class="row g-3" role="group" aria-label="@L["Field.Condition"]">
                            <div class="col-sm-4">
                                <input asp-for="ConditionPref" type="radio" class="option-input" id="cond-new" value="New" autocomplete="off" />
                                <label for="cond-new" class="option-card">
                                    <div class="option-icon"><i class="fa-solid fa-sparkles"></i></div>
                                    <div class="option-title">@L["Field.ConditionNew"]</div>
                                    <div class="option-sub">Brand new</div>
                                </label>
                            </div>
                            <div class="col-sm-4">
                                <input asp-for="ConditionPref" type="radio" class="option-input" id="cond-used" value="Used" autocomplete="off" />
                                <label for="cond-used" class="option-card">
                                    <div class="option-icon"><i class="fa-solid fa-rotate"></i></div>
                                    <div class="option-title">@L["Field.ConditionUsed"]</div>
                                    <div class="option-sub">Pre-owned</div>
                                </label>
                            </div>
                            <div class="col-sm-4">
                                <input asp-for="ConditionPref" type="radio" class="option-input" id="cond-any" value="Any" autocomplete="off" />
                                <label for="cond-any" class="option-card">
                                    <div class="option-icon"><i class="fa-solid fa-shuffle"></i></div>
                                    <div class="option-title">@L["Field.ConditionAny"]</div>
                                    <div class="option-sub">No preference</div>
                                </label>
                            </div>
                        </div>
                        <span asp-validation-for="ConditionPref" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-4">
                        <label class="cf-field-label d-block mb-2">@L["Field.Transmission"]</label>
                        <div class="row g-3" role="group" aria-label="@L["Field.Transmission"]">
                            <div class="col-sm-6">
                                <input asp-for="TransmissionPref" type="radio" class="option-input" id="tr-auto" value="Automatic" autocomplete="off" />
                                <label for="tr-auto" class="option-card">
                                    <div class="option-icon"><i class="fa-solid fa-gauge-high"></i></div>
                                    <div class="option-title">@L["Field.TransmissionAuto"]</div>
                                    <div class="option-sub">Auto gearbox</div>
                                </label>
                            </div>
                            <div class="col-sm-6">
                                <input asp-for="TransmissionPref" type="radio" class="option-input" id="tr-manual" value="Manual" autocomplete="off" />
                                <label for="tr-manual" class="option-card">
                                    <div class="option-icon"><i class="fa-solid fa-gears"></i></div>
                                    <div class="option-title">@L["Field.TransmissionManual"]</div>
                                    <div class="option-sub">Manual gearbox</div>
                                </label>
                            </div>
                        </div>
                        <span asp-validation-for="TransmissionPref" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-4">
                        <label class="cf-field-label d-block mb-2">@L["Field.Size"]</label>
                        <div class="row g-3" role="group" aria-label="@L["Field.Size"]">
                            <div class="col-sm-4">
                                <input asp-for="SizePref" type="radio" class="option-input" id="size-small" value="Small" autocomplete="off" />
                                <label for="size-small" class="option-card">
                                    <div class="option-icon"><i class="fa-solid fa-car-side"></i></div>
                                    <div class="option-title">@L["Field.SizeSmall"]</div>
                                    <div class="option-sub">Compact city car</div>
                                </label>
                            </div>
                            <div class="col-sm-4">
                                <input asp-for="SizePref" type="radio" class="option-input" id="size-med" value="Medium" autocomplete="off" />
                                <label for="size-med" class="option-card">
                                    <div class="option-icon"><i class="fa-solid fa-car"></i></div>
                                    <div class="option-title">@L["Field.SizeMedium"]</div>
                                    <div class="option-sub">Sedan / Hatchback</div>
                                </label>
                            </div>
                            <div class="col-sm-4">
                                <input asp-for="SizePref" type="radio" class="option-input" id="size-suv" value="SUV" autocomplete="off" />
                                <label for="size-suv" class="option-card">
                                    <div class="option-icon"><i class="fa-solid fa-truck-monster"></i></div>
                                    <div class="option-title">@L["Field.SizeSUV"]</div>
                                    <div class="option-sub">Large 4×4</div>
                                </label>
                            </div>
                        </div>
                        <span asp-validation-for="SizePref" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="sticky-cta mt-4 justify-content-between">
                        <button type="submit" name="action" value="back" formnovalidate class="btn btn-outline-secondary fw-bold">
                            <i class="fa fa-arrow-left me-2"></i>@L["Action.Back"]
                        </button>
                        <button type="submit" name="action" value="next" class="btn btn-primary fw-bold">
                            @L["Action.Review"]<i class="fa fa-arrow-right ms-2"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
