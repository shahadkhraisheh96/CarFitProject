@model CarFitProject.ViewModel.QuestionnaireStep1ViewModel
@{
    ViewData["Title"] = "Profile — Basics";
    ViewData["WizardStep"] = 1;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="bg-white shadow-sm rounded-4 p-5">
                <partial name="_WizardProgress" />

                <h2 class="fw-bold text-dark mb-1">Tell us about yourself</h2>
                <p class="text-muted mb-4">A few quick basics to set the tone of your recommendations.</p>

                <form method="post" asp-action="Step1" novalidate>
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="ProfileName" class="form-control border-2" placeholder="Profile name" />
                        <label asp-for="ProfileName" class="fw-bold text-secondary"></label>
                        <span asp-validation-for="ProfileName" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Age" type="number" min="18" max="100" class="form-control border-2" placeholder="Age" />
                        <label asp-for="Age" class="fw-bold text-secondary"></label>
                        <span asp-validation-for="Age" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-4">
                        <label class="fw-bold text-secondary d-block mb-2">Marital status</label>
                        <div class="btn-group" role="group" aria-label="Marital status">
                            <input asp-for="MaritalStatus" type="radio" class="btn-check" id="ms-single" value="Single" autocomplete="off" />
                            <label for="ms-single" class="btn btn-outline-primary">Single</label>
                            <input asp-for="MaritalStatus" type="radio" class="btn-check" id="ms-married" value="Married" autocomplete="off" />
                            <label for="ms-married" class="btn btn-outline-primary">Married</label>
                        </div>
                        <span asp-validation-for="MaritalStatus" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="d-flex justify-content-between gap-2">
                        <button type="submit" name="action" value="back" formnovalidate class="btn btn-outline-secondary fw-bold">
                            <i class="fa fa-xmark me-1"></i>Cancel
                        </button>
                        <button type="submit" name="action" value="next" class="btn btn-primary fw-bold">
                            Next<i class="fa fa-arrow-right ms-2"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
