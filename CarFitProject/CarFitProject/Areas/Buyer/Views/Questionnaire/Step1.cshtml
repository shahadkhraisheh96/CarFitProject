@model CarFitProject.ViewModel.QuestionnaireStep1ViewModel
@{
    ViewData["Title"] = L["Wizard.Step1.Title"].Value;
    ViewData["WizardStep"] = 1;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <partial name="_WizardProgress" />
            <div class="form-section-card">
                <div class="section-heading">
                    <h2>@L["Wizard.Step1.Title"]</h2>
                </div>
                <p class="cf-subtitle mb-4">@L["Wizard.Step1.Subtitle"]</p>

                <form method="post" asp-action="Step1" novalidate>
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                    <div class="form-floating mb-3 cf-floating">
                        <input asp-for="ProfileName" class="form-control" placeholder=" " />
                        <label asp-for="ProfileName"></label>
                        <span asp-validation-for="ProfileName" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="form-floating mb-4 cf-floating">
                        <input asp-for="Age" type="number" min="18" max="100" class="form-control" placeholder=" " />
                        <label asp-for="Age"></label>
                        <span asp-validation-for="Age" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-4">
                        <label class="cf-field-label d-block mb-2">@L["Field.MaritalStatus"]</label>
                        <div class="row g-3" role="group" aria-label="@L["Field.MaritalStatus"]">
                            <div class="col-sm-6">
                                <input asp-for="MaritalStatus" type="radio" class="option-input" id="ms-single" value="Single" autocomplete="off" />
                                <label for="ms-single" class="option-card">
                                    <div class="option-icon"><i class="fa-solid fa-user"></i></div>
                                    <div class="option-title">@L["Field.MaritalSingle"]</div>
                                    <div class="option-sub">Unmarried</div>
                                </label>
                            </div>
                            <div class="col-sm-6">
                                <input asp-for="MaritalStatus" type="radio" class="option-input" id="ms-married" value="Married" autocomplete="off" />
                                <label for="ms-married" class="option-card">
                                    <div class="option-icon"><i class="fa-solid fa-user-group"></i></div>
                                    <div class="option-title">@L["Field.MaritalMarried"]</div>
                                    <div class="option-sub">With partner</div>
                                </label>
                            </div>
                        </div>
                        <span asp-validation-for="MaritalStatus" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="sticky-cta mt-4 justify-content-between">
                        <button type="submit" name="action" value="back" formnovalidate class="btn btn-outline-secondary fw-bold">
                            <i class="fa fa-xmark me-1"></i>@L["Action.Cancel"]
                        </button>
                        <button type="submit" name="action" value="next" class="btn btn-primary fw-bold">
                            @L["Action.Next"]<i class="fa fa-arrow-right ms-2"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
