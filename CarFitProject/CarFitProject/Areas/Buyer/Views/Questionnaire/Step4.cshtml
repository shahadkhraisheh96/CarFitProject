@model CarFitProject.ViewModel.QuestionnaireStep4ViewModel
@{
    ViewData["Title"] = L["Wizard.Step4.Title"].Value;
    ViewData["WizardStep"] = 4;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="bg-white shadow-sm rounded-4 p-5">
                <partial name="_WizardProgress" />

                <h2 class="fw-bold text-dark mb-1">@L["Wizard.Step4.Title"]</h2>
                <p class="text-muted mb-4">@L["Wizard.Step4.Subtitle"]</p>

                <form method="post" asp-action="Step4" novalidate>
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                    <div class="row g-3 mb-3">
                        <div class="col-sm-6">
                            <div class="form-floating">
                                <input asp-for="BudgetMin" type="number" min="0" step="100" class="form-control border-2" placeholder="Min" />
                                <label asp-for="BudgetMin" class="fw-bold text-secondary"></label>
                                <span asp-validation-for="BudgetMin" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="form-floating">
                                <input asp-for="BudgetMax" type="number" min="0" step="100" class="form-control border-2" placeholder="Max" />
                                <label asp-for="BudgetMax" class="fw-bold text-secondary"></label>
                                <span asp-validation-for="BudgetMax" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="fw-bold text-secondary d-block mb-2">@L["Field.PaymentMethod"]</label>
                        <div class="btn-group" role="group" aria-label="@L["Field.PaymentMethod"]">
                            <input asp-for="PaymentMethod" type="radio" class="btn-check" id="pm-cash" value="Cash" autocomplete="off" />
                            <label for="pm-cash" class="btn btn-outline-primary">@L["Field.PaymentCash"]</label>
                            <input asp-for="PaymentMethod" type="radio" class="btn-check" id="pm-instal" value="Installments" autocomplete="off" />
                            <label for="pm-instal" class="btn btn-outline-primary">@L["Field.PaymentInstallments"]</label>
                        </div>
                        <span asp-validation-for="PaymentMethod" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="form-floating mb-4" id="instalMonthsWrapper">
                        <input asp-for="InstallmentMonths" type="number" min="1" max="120" class="form-control border-2" placeholder="Installment months" />
                        <label asp-for="InstallmentMonths" class="fw-bold text-secondary"></label>
                        <span asp-validation-for="InstallmentMonths" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="d-flex justify-content-between gap-2">
                        <button type="submit" name="action" value="back" formnovalidate class="btn btn-outline-secondary fw-bold">
                            <i class="fa fa-arrow-left me-2"></i>@L["Action.Back"]
                        </button>
                        <button type="submit" name="action" value="next" class="btn btn-primary fw-bold">
                            @L["Action.Next"]<i class="fa fa-arrow-right ms-2"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var wrapper = document.getElementById('instalMonthsWrapper');
            function syncVisibility() {
                var inst = document.getElementById('pm-instal');
                wrapper.style.display = (inst && inst.checked) ? '' : 'none';
            }
            ['pm-cash','pm-instal'].forEach(function (id) {
                var el = document.getElementById(id);
                if (el) el.addEventListener('change', syncVisibility);
            });
            syncVisibility();
        })();
    </script>
}
