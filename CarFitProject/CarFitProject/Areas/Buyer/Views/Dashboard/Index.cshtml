@model IEnumerable<CarFitProject.ViewModel.RecommendedCarViewModel>
@{
    Layout = "_Layout";
    ViewData["Title"] = L["Dashboard.Title"].Value;
    
    // Grab the multi-profile data collection we stored in the controller's ViewBag
    var profiles = ViewBag.AllUserProfiles as IEnumerable<CarFitProject.Models.UserProfile> ?? new List<CarFitProject.Models.UserProfile>();
    var currentProfileId = ViewBag.CurrentProfileId as int?;
    var currentProfileName = ViewBag.CurrentProfileName as string ?? "Active Profile";
    var savedIds = ViewBag.SavedCarIds as HashSet<int> ?? new HashSet<int>();
    var savedCount = (int)(ViewBag.SavedCount ?? 0);
}

<div class="container py-4">
    <div class="page-hero mb-4">
        <div class="row align-items-center g-3">
            <div class="col-md-12">
                <span class="eyebrow"><i class="fa-solid fa-bolt me-1"></i> FR-5 Matchmaking Pipeline</span>
                <h1 class="mb-2">@L["Dashboard.Title"]</h1>
                <p class="lead mb-0">@L["Dashboard.Subtitle"] — currently viewing as <strong class="text-white">@currentProfileName</strong>.</p>
            </div>
        </div>
    </div>

    <div class="form-section-card mb-4" style="max-width:none; padding:1.5rem 1.75rem;">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
            <div>
                <span class="text-eyebrow d-block">@L["Dashboard.SwitchPersona"]</span>
                <div class="text-muted small">Click a persona below to load its matches.</div>
            </div>
            <div class="d-flex gap-2">
                <a asp-controller="Profiles" asp-action="Index" class="btn btn-sm btn-outline-secondary fw-bold">
                    <i class="fa-solid fa-list-check me-1"></i>@L["Dashboard.ManageProfiles"]
                </a>
                <a asp-controller="Questionnaire" asp-action="Start" class="btn btn-sm btn-primary fw-bold">
                    <i class="fa-solid fa-plus me-1"></i>@L["Dashboard.NewPersona"]
                </a>
            </div>
        </div>

        @if (profiles.Any())
        {
            <div class="row g-2">
                @foreach (var profile in profiles)
                {
                    var isActive = profile.ProfileId == currentProfileId;
                    var initial = string.IsNullOrEmpty(profile.ProfileName) ? "?" : profile.ProfileName.Substring(0, 1).ToUpper();
                    <div class="col-sm-6 col-lg-4">
                        <a asp-action="Index" asp-route-activeProfileId="@profile.ProfileId"
                           class="persona-card d-flex align-items-center gap-3 text-decoration-none @(isActive ? "is-active" : "")">
                            <div class="persona-avatar" style="width:44px;height:44px;border-radius:12px;font-size:1.1rem;">@initial</div>
                            <div class="flex-grow-1">
                                <div class="fw-bold text-dark">@profile.ProfileName</div>
                                <div class="text-muted small">
                                    @if (isActive)
                                    {
                                        <span class="chip chip-success" style="font-size:0.7rem; padding:0.15rem 0.55rem;"><i class="fa fa-circle-check"></i>Active</span>
                                    }
                                    else
                                    {
                                        <span>@(profile.BudgetMin ?? 0)–@profile.BudgetMax JD · @(profile.Purpose ?? "—")</span>
                                    }
                                </div>
                            </div>
                            @if (!isActive)
                            {
                                <i class="fa-solid fa-arrow-right text-muted"></i>
                            }
                        </a>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-3">
                <div class="text-muted mb-2">You haven't created any personas yet.</div>
                <a asp-controller="Questionnaire" asp-action="Start" class="btn btn-primary fw-bold">
                    <i class="fa-solid fa-plus me-1"></i>@L["Dashboard.NewPersona"]
                </a>
            </div>
        }
    </div>

    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon"><i class="fa-solid fa-bullseye"></i></div>
                <div>
                    <div class="stat-value">@(Model?.Count() ?? 0)</div>
                    <div class="stat-label">Matches</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="stat-card stat-success">
                <div class="stat-icon"><i class="fa-solid fa-bookmark"></i></div>
                <div>
                    <div class="stat-value">@savedCount</div>
                    <div class="stat-label">Saved</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="stat-card stat-info">
                <div class="stat-icon"><i class="fa-solid fa-user-gear"></i></div>
                <div>
                    <div class="stat-value">@profiles.Count()</div>
                    <div class="stat-label">Personas</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="stat-card stat-warning">
                <div class="stat-icon"><i class="fa-solid fa-scale-balanced"></i></div>
                <div>
                    <div class="stat-value"><a asp-controller="Compare" asp-action="Index" class="text-decoration-none text-dark">@L["Compare.Button"]</a></div>
                    <div class="stat-label">Side-by-side</div>
                </div>
            </div>
        </div>
    </div>

    <div class="section-heading">
        <h3><i class="fa-solid fa-sparkles me-2 text-primary"></i>@L["Dashboard.Title"]</h3>
    </div>

    @if (ViewBag.BudgetRelaxed == true)
    {
        <div class="alert alert-info d-flex align-items-center gap-2" role="alert">
            <i class="fa fa-circle-info fs-5"></i>
            <div>@(ViewBag.RelaxationMessage as string)</div>
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon"><i class="fa-solid fa-magnifying-glass"></i></div>
            <h3>@L["Dashboard.NoMatches.Title"]</h3>
            <p>@L["Dashboard.NoMatches.Body"]</p>
            <a class="btn btn-primary fw-bold px-4" asp-controller="Questionnaire" asp-action="Start" asp-route-profileId="@currentProfileId">@L["Dashboard.NoMatches.CTA"]</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var car in Model.OrderByDescending(c => c.DynamicMatchScore))
            {
                <div class="col-xl-4 col-md-6">
                    <div class="glass-card h-100 p-0 border-0 overflow-hidden hover-lift bg-white position-relative shadow-sm d-flex flex-column justify-content-between">

                        <div class="position-absolute top-0 end-0 m-3" style="z-index: 2;">
                            <span class="badge badge-match">
                                <i class="fa-solid fa-bolt me-1"></i> @string.Format(L["Dashboard.MatchPercent"].Value, car.DynamicMatchScore)
                            </span>
                        </div>
                        @if (car.CarseerAttached)
                        {
                            <div class="position-absolute top-0 start-0 m-3" style="z-index: 2;">
                                <span class="badge bg-info text-white px-2 py-1 fw-bold"><i class="fa-solid fa-shield-halved me-1"></i>CarSeer</span>
                            </div>
                        }

                        <div>
                            @if (!string.IsNullOrEmpty(car.PrimaryImageUrl))
                            {
                                <img src="@car.PrimaryImageUrl" alt="@car.Make @car.Model" class="w-100" style="height: 180px; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="bg-dark text-white p-4 pt-5" style="background: linear-gradient(135deg, var(--secondary) 0%, var(--secondary-light) 100%);">
                                    <span class="text-white-50 text-uppercase tracking-wider small fw-bold"><i class="fa-solid fa-location-dot me-1"></i> @car.Year @car.City</span>
                                    <h3 class="fw-bold mb-0 text-white text-truncate mt-1">@car.Make @car.Model</h3>
                                </div>
                            }

                            <div class="p-4">
                                <div class="mb-2">
                                    <h4 class="fw-bold mb-0">@car.Make @car.Model</h4>
                                    <div class="text-muted small">@car.Year @(string.IsNullOrEmpty(car.City) ? "" : "· " + car.City)</div>
                                </div>

                                <div class="d-flex justify-content-between align-items-baseline mb-3 border-bottom pb-3">
                                    <div>
                                        <span class="text-muted d-block small">@L["Dashboard.Listing"]</span>
                                        <span class="fs-3 fw-bold text-dark text-nowrap">@car.ListingPrice.ToString("N0") <span class="fs-6 fw-normal text-secondary">JD</span></span>
                                    </div>
                                    <div class="text-end">
                                        <span class="text-muted d-block small">@L["Dashboard.Trust"]</span>
                                        <span class="badge bg-info bg-opacity-10 text-info border border-info px-2 py-1 fw-bold"><i class="fa-solid fa-star me-1 text-info"></i>@car.TrustScore.ToString("F1") / 5</span>
                                    </div>
                                </div>

                                @if (car.IsRisky)
                                {
                                    <div class="alert alert-danger small d-flex align-items-center gap-2 mb-3 py-2" role="alert">
                                        <i class="fa fa-triangle-exclamation"></i>
                                        <span><strong>Flagged risky</strong> — official inspection recommended.</span>
                                    </div>
                                }

                                @if (car.MatchReasons.Any())
                                {
                                    <div class="mb-3">
                                        <div class="small fw-bold text-secondary text-start mb-2"><i class="fa-solid fa-list-check me-1"></i>@L["Dashboard.WhyThisMatch"]</div>
                                        <ul class="list-unstyled mb-0 small">
                                            @foreach (var reason in car.MatchReasons)
                                            {
                                                <li class="mb-1"><i class="fa fa-check text-success me-1"></i>@reason</li>
                                            }
                                        </ul>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="p-4 border-top pt-3 mt-auto d-flex flex-column gap-2">
                            <a asp-controller="Inventory" asp-action="Detail" asp-area="" asp-route-id="@car.ListingId" class="btn btn-primary w-100 fw-bold">
                                @L["Dashboard.ViewListing"] <i class="fa-solid fa-arrow-right-long ms-2"></i>
                            </a>
                            <div class="d-flex gap-2">
                                @{
                                    var isCarSaved = savedIds.Contains(car.CarId);
                                }
                                <form asp-controller="Saved" asp-action="Toggle" method="post" class="m-0 flex-grow-1">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="carId" value="@car.CarId" />
                                    <input type="hidden" name="returnUrl" value="/Buyer/Dashboard?activeProfileId=@currentProfileId" />
                                    <button type="submit" class="btn btn-sm @(isCarSaved ? "btn-danger" : "btn-outline-primary") fw-bold w-100">
                                        <i class="fa @(isCarSaved ? "fa-bookmark-slash" : "fa-bookmark") me-1"></i>@(isCarSaved ? L["Save.Unsave"] : L["Save.Save"])
                                    </button>
                                </form>
                                @if (car.ListingId.HasValue)
                                {
                                    <button type="button" class="btn btn-sm btn-outline-secondary fw-bold compare-toggle"
                                            data-listing-id="@car.ListingId" data-car-label="@car.Make @car.Model">
                                        <i class="fa fa-scale-balanced me-1"></i>@L["Compare.Button"]
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<partial name="_CompareBar" />

@section Scripts {
    <partial name="_CompareBarScripts" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });
        });
    </script>
}