@model CarFitProject.Models.UserProfile
@{
    Layout = "_Layout";
    ViewData["Title"] = "Onboarding Wizard";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            
            <div class="progress mb-4" style="height: 10px; border-radius: 5px; background-color: rgba(30, 27, 75, 0.1);">
                <div id="wizardProgress" class="progress-bar bg-success progress-bar-striped progress-bar-animated" role="progressbar" style="width: 33%;"></div>
            </div>

            <div class="glass-card shadow border-0 bg-white rounded-4 overflow-hidden p-0">
                <div class="text-white text-center py-4 px-5" style="background: linear-gradient(135deg, var(--secondary) 0%, var(--secondary-light) 100%); border-bottom: 2px solid rgba(139, 92, 246, 0.2);">
                    <h3 class="mb-1 fw-bold text-white"><i class="fa-solid fa-wand-magic-sparkles me-2 text-primary-gradient"></i>Build Your CarFit Driver Profile</h3>
                    <p class="mb-0 text-white-50 small">Configure your custom ruleset to filter our market catalog.</p>
                </div>
                
                <div class="p-5">
                    <form asp-action="CreateProfile" method="post" id="carfitWizard">
                        @Html.AntiForgeryToken()

                        <div class="wizard-step" id="step1">
                            <h4 class="text-primary fw-bold mb-4"><span class="badge bg-primary me-2">1</span>Profile Name & Budget Constraints</h4>
                            <div class="mb-4 text-start">
                                <label class="form-label fw-bold text-dark">Name this lifestyle profile</label>
                                <input asp-for="ProfileName" class="form-control form-control-lg border-2" placeholder="e.g., Daily Commute, Family Weekend Trip" required />
                            </div>
                            <div class="row g-4 mb-4 text-start">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold text-secondary">Minimum Budget Target (JD)</label>
                                    <input asp-for="BudgetMin" type="number" class="form-control border-2" value="3000" min="0" required />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold text-secondary">Maximum Budget Cap (JD)</label>
                                    <input asp-for="BudgetMax" type="number" class="form-control border-2" value="15000" min="1" required />
                                </div>
                            </div>
                            <div class="mb-4 text-start">
                                <label class="form-label fw-bold text-dark">Payment Strategy Preference</label>
                                <select asp-for="PaymentMethod" class="form-select border-2">
                                    <option value="Cash">Cash Basis</option>
                                    <option value="Installments">Installment Plans</option>
                                </select>
                            </div>
                            <div class="text-end pt-3 border-top">
                                <button type="button" class="btn btn-primary btn-lg px-5 fw-bold" onclick="goToStep(2)">Next: Habits <i class="fa-solid fa-arrow-right-long ms-2"></i></button>
                            </div>
                        </div>

                        <div class="wizard-step d-none" id="step2">
                            <h4 class="text-primary fw-bold mb-4"><span class="badge bg-primary me-2">2</span>Core Vehicle Utility & Habits</h4>
                            <div class="mb-4 text-start">
                                <label class="form-label fw-bold text-dark">What is your primary use case scenario?</label>
                                <select asp-for="Purpose" class="form-select form-select-lg border-2">
                                    <option value="Commuting">Daily Commuting (Prioritize Fuel Economy)</option>
                                    <option value="Family">Family Trips (Prioritize Space & Safety)</option>
                                    <option value="Off-road">Rugged Driving / Off-road Capability</option>
                                </select>
                            </div>
                            <div class="mb-4 text-start">
                                <label class="form-label fw-bold text-dark">Marital Status</label>
                                <select asp-for="MaritalStatus" class="form-select border-2">
                                    <option value="Single">Single Professional</option>
                                    <option value="Married">Married Household</option>
                                </select>
                            </div>
                            <div class="d-flex justify-content-between pt-3 border-top">
                                <button type="button" class="btn btn-outline-secondary btn-lg px-4" onclick="goToStep(1)"><i class="fa-solid fa-arrow-left-long me-2"></i> Back</button>
                                <button type="button" class="btn btn-primary btn-lg px-4 fw-bold" onclick="goToStep(3)">Next: Specifications <i class="fa-solid fa-arrow-right-long ms-2"></i></button>
                            </div>
                        </div>

                        <div class="wizard-step d-none" id="step3">
                            <h4 class="text-primary fw-bold mb-4"><span class="badge bg-primary me-2">3</span>Mechanical Preferences</h4>
                            <div class="row g-4 mb-4 text-start">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold text-dark">Transmission Preference</label>
                                    <select asp-for="TransmissionPref" class="form-select border-2" required>
                                        <option value="Automatic">Automatic</option>
                                        <option value="Manual">Manual</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold text-dark">Preferred Body Size</label>
                                    <select asp-for="SizePref" class="form-select border-2" required>
                                        <option value="Sedan">Sedan</option>
                                        <option value="SUV">SUV</option>
                                        <option value="Hatchback">Hatchback</option>
                                    </select>
                                </div>
                            </div>
                            <div class="bg-light border-0 p-4 mb-4 rounded-3 text-start">
                                <div class="form-check form-switch p-0 ps-5 fs-5">
                                    <input class="form-check-input ms-n5" type="checkbox" asp-for="HasKids" id="hasKidsToggle" onchange="toggleKidsCounter()">
                                    <label class="form-check-label fw-bold text-dark ps-2" for="hasKidsToggle">Will children travel in this car often?</label>
                                </div>
                                <div id="kidsCountWrapper" class="d-none mt-3">
                                    <label class="form-label fw-bold text-secondary">Number of kids:</label>
                                    <input asp-for="KidsCount" type="number" class="form-control border-2" value="0" min="0" style="max-width: 120px;" />
                                </div>
                            </div>
                            <div class="d-flex justify-content-between pt-3 border-top">
                                <button type="button" class="btn btn-outline-secondary btn-lg px-4" onclick="goToStep(2)"><i class="fa-solid fa-arrow-left-long me-2"></i> Back</button>
                                <button type="submit" class="btn btn-success btn-lg px-5 fw-bold shadow"><i class="fa-solid fa-wand-magic-sparkles me-2"></i>Build My Matches</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function goToStep(step) {
            document.querySelectorAll('.wizard-step').forEach(el => el.classList.add('d-none'));
            document.getElementById('step' + step).classList.remove('d-none');
            
            let progressPct = step === 1 ? 33 : step === 2 ? 66 : 100;
            document.getElementById('wizardProgress').style.width = progressPct + '%';
        }

        function toggleKidsCounter() {
            let isChecked = document.getElementById('hasKidsToggle').checked;
            let counterDiv = document.getElementById('kidsCountWrapper');
            if (isChecked) {
                counterDiv.classList.remove('d-none');
            } else {
                counterDiv.classList.add('d-none');
            }
        }
        
        // Initialize state on load
        document.addEventListener("DOMContentLoaded", function() {
            toggleKidsCounter();
        });
    </script>
}