@model CarFitProject.Helpers.PaginatedList<CarFitProject.Models.CarListing>
@{
    ViewData["Title"] = L["Save.Page.Title"].Value;
    var isPremium = (bool)(ViewBag.IsPremium ?? false);
    var freeLimit = (int)(ViewBag.FreeLimit ?? 3);
    var savedCount = (int)(ViewBag.SavedCount ?? 0);
}

<div class="container py-4">
    <div class="page-hero mb-4">
        <div class="row align-items-center g-3">
            <div class="col-md-8">
                <span class="eyebrow"><i class="fa fa-bookmark me-1"></i> @L["Save.Page.Title"]</span>
                <h1 class="mb-2">@L["Save.Page.Title"]</h1>
                <p class="lead mb-0">
                    @if (isPremium)
                    {
                        <span><i class="fa fa-crown text-warning me-1"></i>@L["Save.Premium.Status"]</span>
                    }
                    else
                    {
                        <span>@string.Format(L["Save.Free.Status"].Value, savedCount, freeLimit)</span>
                    }
                </p>
            </div>
            <div class="col-md-4 text-md-end">
                <a asp-area="" asp-controller="Inventory" asp-action="Search" class="btn btn-primary fw-bold">
                    <i class="fa fa-magnifying-glass me-2"></i>@L["Save.BrowseListings"]
                </a>
            </div>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success" role="alert">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-warning" role="alert">@TempData["ErrorMessage"]</div>
    }

    @{
        // Build a JS lookup so the tray slots can show real make/model labels
        // for any listing on the current page; unknown ids fall back to "#id".
        var savedLabels = Model.ToDictionary(
            l => l.Id,
            l => $"{l.Car?.Make} {l.Car?.Model}".Trim());
    }

    <div id="compareTray" class="form-section-card mb-4" style="max-width:none; padding:1.25rem 1.5rem;">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
            <div>
                <span class="text-eyebrow d-block"><i class="fa fa-scale-balanced me-1"></i>Compare Tray</span>
                <div class="text-muted small">Pick 2–3 cars from your saved list, then open side-by-side comparison.</div>
            </div>
            <div class="d-flex gap-2">
                <button type="button" id="trayClearBtn" class="btn btn-sm btn-outline-secondary fw-bold">
                    <i class="fa fa-eraser me-1"></i>Clear
                </button>
                <a id="trayGoBtn" href="#" class="btn btn-sm btn-primary fw-bold disabled">
                    <i class="fa fa-arrow-right-arrow-left me-1"></i>Open Comparison
                </a>
            </div>
        </div>
        <div class="row g-2" id="traySlots">
            @for (var i = 0; i < 3; i++)
            {
                <div class="col-md-4">
                    <div class="tray-slot" data-slot-index="@i">
                        <div class="tray-slot-empty">
                            <i class="fa fa-plus-circle me-1"></i><span>Slot @(i + 1) · empty</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="section-heading">
        <h3><i class="fa fa-bookmark me-2 text-primary"></i>Saved Cars <span class="chip ms-2">@Model.TotalCount</span></h3>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon"><i class="fa fa-bookmark"></i></div>
            <h3>@L["Save.Empty"]</h3>
            <p>Start browsing the inventory to save cars you're interested in.</p>
            <a asp-area="" asp-controller="Inventory" asp-action="Search" class="btn btn-primary fw-bold">@L["Save.BrowseListings"]</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var l in Model)
            {
                var primary = l.Car?.CarImages?.OrderByDescending(i => i.IsPrimary).ThenBy(i => i.SortOrder).FirstOrDefault();
                <div class="col-md-6 col-lg-4">
                    <div class="listing-card" data-listing-id="@l.Id">
                        <a asp-area="" asp-controller="Inventory" asp-action="Detail" asp-route-id="@l.Id" class="text-decoration-none text-dark">
                            <div class="listing-media">
                                <span class="in-compare-badge chip chip-warning"><i class="fa fa-scale-balanced"></i>In compare</span>
                                @if (primary != null)
                                {
                                    <img src="@primary.Url" alt="@l.Car?.Make @l.Car?.Model" />
                                }
                                else
                                {
                                    <div class="w-100 h-100 d-flex align-items-center justify-content-center text-white-50">
                                        <i class="fa fa-car fs-1"></i>
                                    </div>
                                }
                            </div>
                            <div class="listing-body">
                                <h5 class="fw-bold mb-1">@l.Car?.Make @l.Car?.Model</h5>
                                <div class="d-flex flex-wrap gap-1 mb-2">
                                    <span class="chip"><i class="fa fa-calendar"></i>@l.Car?.Year</span>
                                    @if (!string.IsNullOrEmpty(l.Car?.Transmission))
                                    { <span class="chip"><i class="fa fa-gears"></i>@l.Car.Transmission</span> }
                                    @if (!string.IsNullOrEmpty(l.Car?.Type))
                                    { <span class="chip"><i class="fa fa-car-side"></i>@l.Car.Type</span> }
                                </div>
                                <div class="price-tag mt-auto pt-2">@(l.ListingPrice?.ToString("N0")) <small>JD</small></div>
                            </div>
                        </a>
                        <div class="listing-foot border-top pt-3 d-flex flex-row gap-2">
                            <form asp-action="Toggle" method="post" class="m-0 flex-grow-1">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="carId" value="@l.CarId" />
                                <button type="submit" class="btn btn-outline-danger fw-bold w-100">
                                    <i class="fa fa-bookmark-slash me-1"></i>@L["Save.Unsave"]
                                </button>
                            </form>
                            <button type="button" class="btn btn-outline-secondary fw-bold compare-toggle"
                                    data-listing-id="@l.Id" data-car-label="@l.Car?.Make @l.Car?.Model">
                                <i class="fa fa-scale-balanced me-1"></i>@L["Compare.Button"]
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
        <partial name="_Pager" model="@(new CarFitProject.ViewModel.PagerViewModel { Page = Model.PageIndex, TotalPages = Model.TotalPages, Action = "Index", Controller = "Saved" })" />
    }
</div>

<partial name="_CompareBar" />

<style>
    .listing-card { position: relative; }
    .listing-card .in-compare-badge {
        position: absolute; top: 10px; left: 10px; z-index: 2;
        font-size: 0.7rem; padding: 0.25rem 0.6rem;
        display: none;
    }
    .listing-card.is-in-compare .in-compare-badge { display: inline-flex; }
    .listing-card.is-in-compare { outline: 2px solid var(--warning); outline-offset: -2px; }

    .tray-slot {
        background: #fff;
        border: 1.5px dashed rgba(26, 26, 46, 0.18);
        border-radius: 14px;
        padding: 0.85rem 1rem;
        min-height: 64px;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        transition: 0.2s ease;
    }
    .tray-slot.is-filled {
        border-style: solid;
        border-color: var(--primary);
        background: rgba(216, 19, 36, 0.04);
        box-shadow: 0 2px 8px rgba(13, 13, 22, 0.06);
    }
    .tray-slot-empty {
        color: #94a3b8;
        font-weight: 600;
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }
    .tray-slot-filled {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        width: 100%;
    }
    .tray-slot-thumb {
        width: 38px; height: 38px;
        border-radius: 10px;
        background: var(--primary-gradient);
        color: #fff;
        display: grid; place-items: center;
        font-size: 0.9rem;
        flex-shrink: 0;
    }
    .tray-slot-label { font-weight: 700; color: var(--secondary); font-size: 0.9rem; flex-grow: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .tray-slot-remove {
        background: transparent; border: none; color: #94a3b8;
        font-size: 1rem; cursor: pointer; padding: 4px 6px; border-radius: 6px;
    }
    .tray-slot-remove:hover { color: var(--danger); background: rgba(239, 68, 68, 0.08); }
</style>

@section Scripts {
    <partial name="_CompareBarScripts" />
    <script>
        (function () {
            var KEY = 'carfit.compare';
            var LABELS = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(savedLabels));

            function readIds() {
                try {
                    var raw = sessionStorage.getItem(KEY);
                    if (!raw) return [];
                    var arr = JSON.parse(raw);
                    return Array.isArray(arr) ? arr : [];
                } catch (_) { return []; }
            }
            function labelFor(id) {
                return LABELS[id] || ('Listing #' + id);
            }
            function renderTray() {
                var ids = readIds();
                var slots = document.querySelectorAll('#traySlots .tray-slot');
                slots.forEach(function (slot, i) {
                    var id = ids[i];
                    if (id) {
                        var initial = (labelFor(id).charAt(0) || '?').toUpperCase();
                        slot.classList.add('is-filled');
                        slot.innerHTML =
                            '<div class="tray-slot-filled">' +
                                '<div class="tray-slot-thumb">' + initial + '</div>' +
                                '<div class="tray-slot-label">' + labelFor(id) + '</div>' +
                                '<button type="button" class="tray-slot-remove" data-remove-id="' + id + '" aria-label="Remove"><i class="fa fa-xmark"></i></button>' +
                            '</div>';
                    } else {
                        slot.classList.remove('is-filled');
                        slot.innerHTML =
                            '<div class="tray-slot-empty">' +
                                '<i class="fa fa-plus-circle me-1"></i><span>Slot ' + (i + 1) + ' · empty</span>' +
                            '</div>';
                    }
                });

                // Highlight saved cards in compare
                document.querySelectorAll('.listing-card[data-listing-id]').forEach(function (card) {
                    var lid = parseInt(card.getAttribute('data-listing-id'), 10);
                    card.classList.toggle('is-in-compare', ids.indexOf(lid) >= 0);
                });

                var go = document.getElementById('trayGoBtn');
                if (ids.length >= 2) {
                    go.classList.remove('disabled');
                    go.href = '/Buyer/Compare?ids=' + ids.join(',');
                } else {
                    go.classList.add('disabled');
                    go.href = '#';
                }
            }

            document.addEventListener('click', function (e) {
                var rm = e.target.closest('[data-remove-id]');
                if (rm) {
                    var id = parseInt(rm.getAttribute('data-remove-id'), 10);
                    var ids = readIds().filter(function (x) { return x !== id; });
                    sessionStorage.setItem(KEY, JSON.stringify(ids));
                    renderTray();
                    return;
                }
                if (e.target.closest('#trayClearBtn')) {
                    sessionStorage.removeItem(KEY);
                    renderTray();
                }
            });

            // The CompareBarScripts rerenders its bar on click; we piggyback via a quick poll
            // so the tray stays in sync without coupling the two scripts.
            var last = '';
            setInterval(function () {
                var cur = sessionStorage.getItem(KEY) || '';
                if (cur !== last) { last = cur; renderTray(); }
            }, 400);

            renderTray();
        })();
    </script>
}
