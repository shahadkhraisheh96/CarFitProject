@{
    var currentStep = (int)(ViewData["WizardStep"] ?? 1);
    var totalSteps = 6;
    var pct = (int)Math.Round(100d * currentStep / totalSteps);
    var labelKeys = new[]
    {
        "Wizard.Step.Basics",
        "Wizard.Step.Family",
        "Wizard.Step.PurposeTrip",
        "Wizard.Step.Budget",
        "Wizard.Step.Preferences",
        "Wizard.Step.Review"
    };
}

<div class="mb-4">
    <div class="wizard-stepper d-none d-md-flex" aria-label="Questionnaire progress">
        @for (var i = 1; i <= totalSteps; i++)
        {
            var state = i < currentStep ? "is-done" : (i == currentStep ? "is-active" : "");
            <div class="wizard-step @state">
                <span class="step-bullet">
                    @if (i < currentStep)
                    {
                        <i class="fa-solid fa-check"></i>
                    }
                    else
                    {
                        @i
                    }
                </span>
                <span class="step-label">@L[labelKeys[i - 1]]</span>
            </div>
            if (i < totalSteps)
            {
                <span class="wizard-connector" aria-hidden="true"></span>
            }
        }
    </div>

    <div class="d-md-none">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <small class="text-eyebrow">@string.Format(L["Wizard.StepOfN"].Value, currentStep, totalSteps)</small>
            <small class="text-muted fw-bold">@L[labelKeys[currentStep - 1]]</small>
        </div>
        <div class="progress" role="progressbar" aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100" style="height: 8px; border-radius: 50px;">
            <div class="progress-bar" style="width: @pct%; background: var(--primary-gradient);"></div>
        </div>
    </div>
</div>
