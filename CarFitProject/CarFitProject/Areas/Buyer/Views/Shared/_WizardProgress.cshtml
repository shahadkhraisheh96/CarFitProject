@{
    var currentStep = (int)(ViewData["WizardStep"] ?? 1);
    var totalSteps = 6;
    var pct = (int)Math.Round(100d * currentStep / totalSteps);
    var labels = new[] { "Basics", "Family", "Purpose & Trip", "Budget", "Preferences", "Review" };
}

<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <small class="text-muted fw-bold">Step @currentStep of @totalSteps</small>
        <small class="text-muted">@labels[currentStep - 1]</small>
    </div>
    <div class="progress" role="progressbar" aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100" style="height: 8px;">
        <div class="progress-bar bg-primary" style="width: @pct%"></div>
    </div>
</div>
