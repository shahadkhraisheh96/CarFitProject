@model List<CarFitProject.Models.UserProfile>
@{
    ViewData["Title"] = "My Profiles";
}

<div class="container py-5">
    <div class="row mb-4 align-items-center">
        <div class="col">
            <h2 class="fw-bold text-dark mb-1">My profiles</h2>
            <p class="text-muted mb-0">Create, edit, and switch between your CarFit lifestyle profiles.</p>
        </div>
        <div class="col-auto">
            <a asp-action="Start" asp-controller="Questionnaire" class="btn btn-primary fw-bold">
                <i class="fa fa-plus me-2"></i>New profile
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success" role="alert">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger" role="alert">@TempData["ErrorMessage"]</div>
    }

    @if (!Model.Any())
    {
        <div class="bg-white shadow-sm rounded-4 p-5 text-center">
            <i class="fa fa-clipboard-list fs-1 text-muted opacity-25 mb-3 d-block"></i>
            <p class="text-muted mb-3">You don't have any profiles yet.</p>
            <a asp-action="Start" asp-controller="Questionnaire" class="btn btn-primary fw-bold">
                Start the questionnaire
            </a>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var profile in Model)
            {
                <div class="col-md-6">
                    <div class="bg-white shadow-sm rounded-4 p-4 h-100 d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="fw-bold mb-0">@profile.ProfileName</h5>
                            @if (profile.IsActive == true)
                            {
                                <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-3 py-1 fw-bold">Active</span>
                            }
                        </div>

                        <div class="text-muted small mb-3">
                            <div>Budget: @(profile.BudgetMin ?? 0) – @profile.BudgetMax JD</div>
                            <div>@(profile.Purpose ?? "—") · @(profile.TransmissionPref ?? "—") · @(profile.SizePref ?? "—")</div>
                        </div>

                        <div class="d-flex flex-wrap gap-2 mt-auto">
                            <a asp-action="Start" asp-controller="Questionnaire" asp-route-profileId="@profile.ProfileId"
                               class="btn btn-sm btn-outline-primary fw-bold">
                                <i class="fa fa-pen me-1"></i>Edit
                            </a>

                            @if (profile.IsActive != true)
                            {
                                <form asp-action="Activate" method="post" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@profile.ProfileId" />
                                    <button type="submit" class="btn btn-sm btn-outline-success fw-bold">
                                        <i class="fa fa-circle-check me-1"></i>Activate
                                    </button>
                                </form>
                            }

                            <button type="button" class="btn btn-sm btn-outline-secondary fw-bold"
                                    data-bs-toggle="collapse" data-bs-target="#rename-@profile.ProfileId">
                                <i class="fa fa-tag me-1"></i>Rename
                            </button>

                            <form asp-action="Delete" method="post" class="m-0"
                                  onsubmit="return confirm('Delete this profile? This cannot be undone.');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@profile.ProfileId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger fw-bold">
                                    <i class="fa fa-trash me-1"></i>Delete
                                </button>
                            </form>
                        </div>

                        <div class="collapse mt-3" id="rename-@profile.ProfileId">
                            <form asp-action="Rename" method="post" class="d-flex gap-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@profile.ProfileId" />
                                <input type="text" name="profileName" class="form-control form-control-sm" value="@profile.ProfileName" required maxlength="100" />
                                <button type="submit" class="btn btn-sm btn-primary fw-bold">Save</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
