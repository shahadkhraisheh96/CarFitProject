@model CarFitProject.ViewModel.CarListingFormViewModel
@{
    Layout = "_Layout";
    var isEdit = Model.ListingId.HasValue;
    ViewData["Title"] = (isEdit ? SharedLocalizer["Admin.Listings.Form.Edit"] : SharedLocalizer["Admin.Listings.Form.Create"]).Value;
    var sellers = ViewBag.AvailableSellers as List<CarFitProject.Models.Seller> ?? new List<CarFitProject.Models.Seller>();
    var currentSellerId = ViewBag.CurrentSellerId as int?;
    var actionName = isEdit ? "Edit" : "Create";
}

<div class="row align-items-center mb-3">
    <div class="col">
        <a asp-action="Index" class="text-decoration-none small text-primary fw-bold"><i class="fa fa-arrow-left me-1"></i>Back to listings</a>
        <h2 class="text-white fw-bold mt-2 mb-0">@ViewData["Title"]</h2>
    </div>
</div>

<div class="admin-card p-4">
    <form asp-action="@actionName" asp-route-id="@(isEdit ? Model.ListingId : (int?)null)" method="post" enctype="multipart/form-data" novalidate>
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>
        <input type="hidden" asp-for="ListingId" />
        <input type="hidden" asp-for="CarId" />

        @if (!isEdit)
        {
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="text-muted small fw-bold">Dealer</label>
                    <select name="sellerId" class="form-select">
                        <option value="">— pick a dealer —</option>
                        @foreach (var s in sellers)
                        {
                            <option value="@s.Id">@s.Name @(s.IsApproved ? "" : "(pending)")</option>
                        }
                    </select>
                    <span class="text-danger small d-block mt-1">@Html.ValidationMessage("sellerId")</span>
                </div>
                <div class="col-md-3">
                    <label class="text-muted small fw-bold">Status</label>
                    <select asp-for="Status" class="form-select">
                        <option value="Active">Active</option>
                        <option value="Pending">Pending</option>
                        <option value="Sold">Sold</option>
                    </select>
                </div>
            </div>
        }
        else
        {
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="text-muted small fw-bold">Dealer</label>
                    <input value="@(sellers.FirstOrDefault(s => s.Id == currentSellerId)?.Name ?? "(unknown)")" class="form-control" disabled readonly />
                </div>
                <div class="col-md-3">
                    <label class="text-muted small fw-bold">Status</label>
                    <select asp-for="Status" class="form-select">
                        <option value="Active">Active</option>
                        <option value="Pending">Pending</option>
                        <option value="Sold">Sold</option>
                    </select>
                </div>
            </div>
        }

        <h5 class="text-white fw-bold mt-2 mb-3">Vehicle</h5>
        <div class="row g-3">
            <div class="col-md-6"><div class="form-floating"><input asp-for="Make" class="form-control" placeholder="Make" /><label asp-for="Make"></label><span asp-validation-for="Make" class="text-danger small"></span></div></div>
            <div class="col-md-6"><div class="form-floating"><input asp-for="Model" class="form-control" placeholder="Model" /><label asp-for="Model"></label><span asp-validation-for="Model" class="text-danger small"></span></div></div>
            <div class="col-md-3"><div class="form-floating"><input asp-for="Year" type="number" class="form-control" placeholder="Year" /><label asp-for="Year"></label><span asp-validation-for="Year" class="text-danger small"></span></div></div>
            <div class="col-md-3"><div class="form-floating"><select asp-for="Type" class="form-select"><option value="Used">Used</option><option value="New">New</option></select><label asp-for="Type"></label></div></div>
            <div class="col-md-3"><div class="form-floating"><input asp-for="Trim" class="form-control" placeholder="Trim" /><label asp-for="Trim"></label></div></div>
            <div class="col-md-3"><div class="form-floating"><select asp-for="Transmission" class="form-select"><option value="Automatic">Automatic</option><option value="Manual">Manual</option></select><label asp-for="Transmission"></label></div></div>
            <div class="col-md-4"><div class="form-floating"><input asp-for="EngineSize" class="form-control" placeholder="Engine" /><label asp-for="EngineSize"></label></div></div>
            <div class="col-md-4"><div class="form-floating"><input asp-for="FuelType" class="form-control" placeholder="Fuel" /><label asp-for="FuelType"></label></div></div>
            <div class="col-md-4"><div class="form-floating"><input asp-for="BodyType" class="form-control" placeholder="Body" /><label asp-for="BodyType"></label></div></div>
            <div class="col-md-3"><div class="form-floating"><input asp-for="Seats" type="number" class="form-control" placeholder="Seats" /><label asp-for="Seats"></label></div></div>
            <div class="col-md-3"><div class="form-floating"><input asp-for="Kilometers" class="form-control" placeholder="Mileage" /><label asp-for="Kilometers"></label></div></div>
            <div class="col-md-3"><div class="form-floating"><input asp-for="ExteriorColor" class="form-control" placeholder="Exterior" /><label asp-for="ExteriorColor"></label></div></div>
            <div class="col-md-3"><div class="form-floating"><input asp-for="InteriorColor" class="form-control" placeholder="Interior" /><label asp-for="InteriorColor"></label></div></div>
        </div>

        <hr class="my-4 border-secondary" />
        <h5 class="text-white fw-bold mb-3">Listing</h5>
        <div class="row g-3">
            <div class="col-md-4"><div class="form-floating"><input asp-for="ListingPrice" type="number" class="form-control" placeholder="Price" /><label asp-for="ListingPrice"></label><span asp-validation-for="ListingPrice" class="text-danger small"></span></div></div>
            <div class="col-md-5"><div class="form-floating"><input asp-for="PaymentMethodAllowed" class="form-control" placeholder="Payment" /><label asp-for="PaymentMethodAllowed"></label></div></div>
            <div class="col-md-3 d-flex align-items-center"><div class="form-check"><input asp-for="InstallmentOption" class="form-check-input" type="checkbox" /><label asp-for="InstallmentOption" class="form-check-label text-white"></label></div></div>
        </div>

        <hr class="my-4 border-secondary" />
        <h5 class="text-white fw-bold mb-3">Photos</h5>
        @if (Model.ExistingImages.Any())
        {
            <div class="row g-3 mb-3">
                @foreach (var img in Model.ExistingImages)
                {
                    <div class="col-6 col-md-3">
                        <div class="position-relative border rounded overflow-hidden">
                            <img src="@img.Url" class="img-fluid d-block w-100" style="height: 110px; object-fit: cover;" />
                            @if (img.IsPrimary){<span class="badge bg-primary position-absolute top-0 start-0 m-1">Primary</span>}
                            <form asp-action="DeleteImage" method="post" class="position-absolute top-0 end-0 m-1" onsubmit="return confirm('Remove this photo?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@img.Id" />
                                <input type="hidden" name="listingId" value="@Model.ListingId" />
                                <button type="submit" class="btn btn-sm btn-danger"><i class="fa fa-xmark"></i></button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
        <div class="mb-3">
            <label class="text-muted small fw-bold d-block mb-1">Upload photos (3–15 total)</label>
            <input type="file" name="images" class="form-control" multiple accept="image/*" />
            <span class="text-danger small d-block mt-1">@Html.ValidationMessage("images")</span>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-3">
            <a asp-action="Index" class="btn btn-outline-light fw-bold">Cancel</a>
            <button type="submit" class="btn btn-primary fw-bold"><i class="fa fa-floppy-disk me-1"></i>@(isEdit ? "Save" : "Create")</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
