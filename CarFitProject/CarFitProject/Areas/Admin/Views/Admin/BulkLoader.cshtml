@model CarFitProject.Areas.Admin.Models.BulkImportViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = SharedLocalizer["Admin.BulkLoader.Title"].Value;
}

<style>
    .widescreen-wrapper {
        width: 100% !important;
        padding: 0 !important;
        margin: 0 !important;
    }
</style>

<div class="widescreen-wrapper">
    <div class="row mb-4">
        <div class="col-12">
            <div class="admin-card d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3">
                <div>
                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="text-decoration-none text-primary small d-inline-block mb-2 fw-bold">
                        <i class="fa fa-arrow-left me-1"></i> Back to Control Base
                    </a>
                    <h2 class="text-white fw-bold mb-1">
                        <i class="fa-solid fa-file-csv me-2 text-primary"></i>Bulk CSV Loader Matrix (FR-7.2)
                    </h2>
                    <p class="text-muted mb-0 small">
                        Import batch vehicle assets straight into the active inventory databases via secondary source datasets.
                    </p>
                </div>
                <div>
                    <span class="badge badge-critical px-3 py-2 text-uppercase tracking-wider" style="font-size: 0.75rem;">Data Stream Core</span>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12 col-lg-6">
            <div class="admin-card h-100">
                <h5 class="fw-bold text-white mb-3"><i class="fa-solid fa-upload text-primary me-2"></i>Select Scraped Data Target</h5>
                <p class="text-muted small mb-4">Upload a standardized `.csv` data sheet matching the column profile map.</p>

                <form asp-area="Admin" asp-controller="Admin" asp-action="BulkLoader" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted mb-2">CSV Data Source Attachment File</label>
                        <input type="file" name="csvFile" class="form-control" accept=".csv" required />
                        <div class="form-text text-muted small mt-1">Maximum allocation boundary: 10MB per stream pool batch.</div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2.5 fw-bold shadow-sm d-flex align-items-center justify-content-center gap-2">
                        <i class="fa-solid fa-cloud-arrow-up"></i> Initialize Pipeline Stream
                    </button>
                </form>
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="admin-card h-100 d-flex flex-column justify-content-between">
                <div>
                    <h5 class="fw-bold text-white mb-3"><i class="fa-solid fa-square-poll-vertical text-primary me-2"></i>Pipeline Stream Status Monitoring</h5>
                    
                    @if (Model != null && Model.IsSuccess)
                    {
                        <div class="badge badge-low d-flex align-items-center gap-2 p-3 mb-4 rounded-3">
                            <i class="fa-solid fa-circle-check fs-5"></i>
                            <div class="text-start">
                                <div class="fw-bold text-white">Import Execution Complete</div>
                                <div class="small opacity-75">Successfully processed and buffered <span class="fw-bold font-monospace">@Model.InsertedCount</span> inventory items.</div>
                            </div>
                        </div>
                    }
                    else if (Model != null && Model.ErrorMessages != null && Model.ErrorMessages.Any())
                    {
                        <div class="badge badge-critical d-flex align-items-start gap-2 p-3 mb-4 rounded-3 text-wrap text-start">
                            <i class="fa-solid fa-triangle-exclamation fs-5 mt-0.5"></i>
                            <div>
                                <div class="fw-bold text-white">Processing Exceptions Logged</div>
                                <ul class="small mb-0 mt-1 ps-3 opacity-75">
                                    @foreach (var error in Model.ErrorMessages)
                                    {
                                        <li>@error</li>
                                    }
                                </ul>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-5 my-3">
                            <i class="fa-solid fa-network-wired fs-1 mb-3 text-muted opacity-25"></i>
                            <p class="small mb-0">Pipeline idle. Connect a CSV data handle payload to map active array elements.</p>
                        </div>
                    }
                </div>

                <div class="p-3 bg-dark rounded-3 border border-dim">
                    <div class="small fw-bold text-white mb-2 text-uppercase tracking-wider" style="font-size:0.75rem;">Expected Column Map Matrix Template</div>
                    <code class="font-monospace text-primary small bg-transparent p-0 d-block text-break">Make, Model, Year, Trim, ListingPrice</code>
                </div>
            </div>
        </div>
    </div>
</div>