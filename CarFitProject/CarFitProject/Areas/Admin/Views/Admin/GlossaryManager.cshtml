@model List<CarFitProject.Models.InspectionTermsGlossary>
@using Microsoft.AspNetCore.Html
@using System.Text.Encodings.Web
@{
    Layout = "_Layout";
    ViewData["Title"] = SharedLocalizer["Admin.Glossary.Title"].Value;
}

<style>
    .widescreen-wrapper {
        width: 100% !important;
        padding: 0 !important;
        margin: 0 !important;
    }

    .custom-glossary-table th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.05rem;
        background-color: var(--bg-sidebar) !important;
        border-bottom: 1px solid var(--border-dim) !important;
        padding: 14px 12px !important;
    }

    .custom-glossary-table td {
        border-bottom: 1px solid var(--border-dim) !important;
        padding: 1rem 0.75rem !important;
    }

    .custom-glossary-table tbody tr:hover {
        background-color: rgba(255, 255, 255, 0.015) !important;
    }
</style>

<div class="widescreen-wrapper">
    <div class="row mb-4">
        <div class="col-12">
            <div class="admin-card d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3">
                <div>
                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="text-decoration-none text-primary small d-inline-block mb-2 fw-bold">
                        <i class="fa fa-arrow-left me-1"></i> Back to Control Base
                    </a>
                    <h2 class="text-white fw-bold mb-1">
                        <i class="fa fa-book me-2 text-primary"></i>Bilingual Inspection Glossary (FR-7.4)
                    </h2>
                    <p class="text-muted mb-0 small">
                        Manage Arabic vehicle inspection shorthand mechanics and their plain-language explanations.
                    </p>
                </div>
                <div class="mt-2 mt-sm-0">
                    <button type="button" class="btn btn-primary fw-bold px-4 shadow-sm" onclick="openGlossaryModal('', '', '', 'Low')">
                        <i class="fa fa-plus me-1"></i> Add New Term
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="admin-card p-0 overflow-hidden shadow-sm">
                <div class="py-3 px-4 border-bottom d-flex justify-content-between align-items-center" style="background: rgba(0,0,0,0.15); border-color: var(--border-dim) !important;">
                    <h5 class="mb-0 fw-bold text-white fs-6"><i class="fa-solid fa-book-open me-2 text-primary"></i>Technical Terminology Dictionary Mapping</h5>
                    <span class="badge badge-low font-monospace">@(Model?.Count ?? 0) Active Keys</span>
                </div>

                <div class="table-responsive">
                    <table class="table text-start align-middle mb-0 table-hover w-100 custom-glossary-table">
                        <thead>
                            <tr class="text-white">
                                <th scope="col" style="width: 20%;" class="ps-4">Inspection Term (Keyword)</th>
                                <th scope="col" style="width: 15%;">Severity Risk</th>
                                <th scope="col" style="width: 25%;">Arabic Explanation (ورقة الفحص)</th>
                                <th scope="col" style="width: 28%;">English Translation Summary</th>
                                <th scope="col" class="text-center" style="width: 12%;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model == null || !Model.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">
                                        <i class="fa fa-book-open fs-1 mb-3 d-block text-primary opacity-25"></i>
                                        No technical terminology mapped in the database glossary yet.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="text-white fw-bold ps-4 font-monospace" dir="rtl">@item.Term</td>
                                        <td>
                                            @switch (item.SeverityLevel)
                                            {
                                                case "Critical":
                                                    <span class="badge badge-critical px-2 py-1.5 rounded text-uppercase" style="font-size:0.7rem;">Critical Risk</span>
                                                    break;
                                                case "High":
                                                    <span class="badge badge-high px-2 py-1.5 rounded text-uppercase" style="font-size:0.7rem;">High Risk</span>
                                                    break;
                                                case "Medium":
                                                    <span class="badge badge-medium px-2 py-1.5 rounded text-uppercase" style="font-size:0.7rem;">Medium Risk</span>
                                                    break;
                                                default:
                                                    <span class="badge badge-low px-2 py-1.5 rounded text-uppercase" style="font-size:0.7rem;">Low Risk</span>
                                                    break;
                                            }
                                        </td>
                                        <td class="text-muted" dir="rtl">@item.ExplanationAr</td>
                                        <td class="text-white-50">@item.ExplanationEn</td>
                                        <td class="text-center pe-4">
                                            <button type="button" class="btn btn-sm btn-outline-primary fw-bold px-3" onclick="openGlossaryModal('@JavaScriptEncoder.Default.Encode(item.Term)', '@JavaScriptEncoder.Default.Encode(item.ExplanationAr ?? "")', '@JavaScriptEncoder.Default.Encode(item.ExplanationEn ?? "")', '@item.SeverityLevel')">Edit Term</button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="glossaryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content text-white border-1" style="background-color: var(--bg-card); border-color: var(--border-dim);">
            <div class="modal-header border-bottom" style="border-color: var(--border-dim) !important;">
                <h5 class="modal-title fw-bold" id="modalHeaderTitle">Manage Glossary Term</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-area="Admin" asp-controller="Admin" asp-action="UpdateGlossaryTerm" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Inspection Keyword / Shorthand (Arabic)</label>
                        <input type="text" name="Term" id="modalTermInput" class="form-control text-white text-end" dir="rtl" placeholder="مثال: قصعة شاصي, جيد خلفي" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Structural Severity Impact Level</label>
                        <select name="SeverityLevel" id="modalSeverityInput" class="form-select text-white">
                            <option value="Low">Low / Cosmetic Defect</option>
                            <option value="Medium">Medium Wear</option>
                            <option value="High">High / Performance Structural Impact</option>
                            <option value="Critical">Critical Safety Risk</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Arabic Explanation (تفاصيل الفحص ورقة فنية)</label>
                        <textarea name="ExplanationAr" id="modalExplanationArInput" class="form-control text-white text-end" dir="rtl" rows="3" placeholder="شرح مبسط للمصطلح الفني للمشتري العادي..." required></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">English Translation Summary</label>
                        <textarea name="ExplanationEn" id="modalExplanationEnInput" class="form-control text-white" rows="3" placeholder="Plain English explanation summary for buyers..." required></textarea>
                    </div>
                </div>
                <div class="modal-footer border-top" style="border-color: var(--border-dim) !important;">
                    <button type="button" class="btn btn-outline-dark px-3" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary fw-bold px-4">Save Configuration</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openGlossaryModal(term, expAr, expEn, severity) {
            var clearTerm = decodeURIComponent(term);
            var clearAr = decodeURIComponent(expAr);
            var clearEn = decodeURIComponent(expEn);

            if(clearTerm === '') {
                $('#modalHeaderTitle').html('✨ Add New Glossary Term');
                $('#modalTermInput').removeAttr('readonly').val('');
                $('#modalExplanationArInput').val('');
                $('#modalExplanationEnInput').val('');
                $('#modalSeverityInput').val('Low');
            } else {
                $('#modalHeaderTitle').html('⚙️ Edit Technical Term: <span class="text-primary">' + clearTerm + '</span>');
                $('#modalTermInput').attr('readonly', 'readonly').val(clearTerm);
                $('#modalExplanationArInput').val(clearAr);
                $('#modalExplanationEnInput').val(clearEn);
                $('#modalSeverityInput').val(severity);
            }
            
            var targetModal = new bootstrap.Modal(document.getElementById('glossaryModal'));
            targetModal.show();
        }
    </script>
}