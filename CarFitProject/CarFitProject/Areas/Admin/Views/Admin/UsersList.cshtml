@model List<Microsoft.AspNetCore.Identity.IdentityUser>
@{
    Layout = "_Layout";
    ViewData["Title"] = "User Accounts Directory";
}

<style>
    .widescreen-wrapper {
        width: 100% !important;
        padding: 0 !important;
        margin: 0 !important;
    }

    .custom-user-table th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.05rem;
        background-color: var(--bg-sidebar) !important;
        border-bottom: 1px solid var(--border-dim) !important;
        padding: 14px 12px !important;
    }

    .custom-user-table td {
        border-bottom: 1px solid var(--border-dim) !important;
        padding: 1rem 0.75rem !important;
    }

    .style-user-badge {
        font-size: 0.7rem !important;
        letter-spacing: 0.04em;
    }
</style>

<div class="widescreen-wrapper">
    <div class="row mb-4">
        <div class="col-12">
            <div class="admin-card d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3">
                <div>
                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="text-decoration-none text-primary small d-inline-block mb-2 fw-bold">
                        <i class="fa fa-arrow-left me-1"></i> Back to Control Base
                    </a>
                    <h2 class="text-white fw-bold mb-1">
                        <i class="fa-solid fa-users-gear me-2 text-primary"></i>User Accounts Directory (FR-7.1)
                    </h2>
                    <p class="text-muted mb-0 small">
                        All registered accounts mapped on the CarFit identity manager core. Total active nodes: <strong class="text-white font-monospace">@(Model?.Count ?? 0)</strong>
                    </p>
                </div>
                <div>
                    <span class="badge badge-critical px-3 py-2 text-uppercase tracking-wider" style="font-size: 0.75rem;">Live Registry</span>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="admin-card p-0 overflow-hidden shadow-sm">
                <div class="py-3 px-4 border-bottom d-flex justify-content-between align-items-center" style="background: rgba(0,0,0,0.15); border-color: var(--border-dim) !important;">
                    <h5 class="mb-0 fw-bold text-white fs-6"><i class="fa-solid fa-table-list me-2 text-primary"></i>Registered Platform Users</h5>
                    <span class="badge badge-low font-monospace">@(Model?.Count ?? 0) Accounts</span>
                </div>

                <div class="table-responsive">
                    <table class="table text-start align-middle mb-0 table-hover w-100 custom-user-table">
                        <thead>
                            <tr>
                                <th class="ps-4" style="width: 8%;">#</th>
                                <th style="width: 32%;">Username</th>
                                <th style="width: 30%;">Email</th>
                                <th style="width: 18%;">Phone</th>
                                <th class="text-center" style="width: 12%;">Email Confirmed</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model == null || !Model.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">
                                        <i class="fa fa-users-slash fs-2 mb-3 d-block text-primary opacity-25"></i>
                                        No user accounts found in the system logs.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                int row = 1;
                                foreach (var user in Model)
                                {
                                    <tr>
                                        <td class="ps-4 text-muted font-monospace fw-bold">#@row</td>
                                        <td>
                                            <div class="d-flex align-items-center gap-3">
                                                <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold flex-shrink-0 shadow-sm" style="width: 38px; height: 38px; background: var(--primary-gradient); font-size: 0.9rem;">
                                                    @(user.UserName?.Substring(0, 1).ToUpper() ?? "?")
                                                </div>
                                                <span class="text-white fw-semibold">@user.UserName</span>
                                            </div>
                                        </td>
                                        <td class="text-white-50 font-monospace">@user.Email</td>
                                        <td class="text-muted">@(string.IsNullOrEmpty(user.PhoneNumber) ? "—" : user.PhoneNumber)</td>
                                        <td class="text-center pe-4">
                                            @if (user.EmailConfirmed)
                                            {
                                                <span class="badge badge-low d-block py-1.5 text-uppercase style-user-badge">
                                                    <i class="fa fa-check me-1"></i>Verified
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-medium d-block py-1.5 text-uppercase style-user-badge">
                                                    <i class="fa fa-clock me-1"></i>Pending
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                    row++;
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>