@model List<CarFitProject.Models.CarListing>
@{
    Layout = "_Layout";
    ViewData["Title"] = "System Administration Panel";
}

<style>
    .widescreen-wrapper {
        width: 100% !important;
        padding: 0 !important;
        margin: 0 !important;
    }

    .kpi-number {
        font-size: 2.25rem;
        font-weight: 800;
        background: var(--primary-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .meta-year-badge {
        background-color: #0b0f19;
        color: var(--text-muted);
        border: 1px solid var(--border-dim);
    }

    .custom-admin-table th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.05rem;
        background-color: var(--bg-sidebar) !important;
        border-bottom: 1px solid var(--border-dim) !important;
        padding: 14px 12px !important;
    }

    .custom-admin-table td {
        border-bottom: 1px solid var(--border-dim) !important;
        padding: 1rem 0.75rem !important;
    }

    .hover-lift {
        transition: all 0.25s ease;
    }

        .hover-lift:hover {
            transform: translateX(4px);
            color: var(--primary) !important;
        }
</style>

<div class="widescreen-wrapper">
    <div class="row mb-4">
        <div class="col-12">
            <div class="admin-card">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-3 border-bottom border-secondary pb-3" style="border-color: var(--border-dim) !important;">
                    <div>
                        <span class="badge badge-critical mb-2 text-uppercase tracking-wider">FR-7 Administrative Root</span>
                        <h1 class="fw-bold text-white mb-0">
                            <i class="fa-solid fa-server me-2 text-primary"></i>CarFit Central Control Engine
                        </h1>
                    </div>
                    <div class="text-md-end mt-3 mt-md-0">
                        <div class="text-muted small fw-bold text-uppercase tracking-wider">Security Context</div>
                        <span class="badge badge-low mt-1">
                            <i class="fa fa-shield-alt me-1"></i>Authenticated Session
                        </span>
                    </div>
                </div>
                <p class="fs-5 text-muted leading-relaxed mb-0 w-100">
                    Welcome to the administrative master workspace. Use this command center to supervise registered profile layers, balance bilingual glossary tools, and audit system catalog changes.
                </p>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-12 col-md-4">
            <div class="admin-card d-flex align-items-center justify-content-between p-4">
                <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px; background: rgba(216, 19, 36, 0.10); border: 1px solid var(--border-color);">
                    <i class="fa fa-users fa-2x text-primary"></i>
                </div>
                <div class="text-end">
                    <p class="mb-1 text-muted small fw-bold text-uppercase tracking-wider">Platform Users</p>
                    <h2 class="mb-0 kpi-number">@(ViewBag.TotalUsers ?? 0)</h2>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="admin-card d-flex align-items-center justify-content-between p-4">
                <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px; background: rgba(16, 185, 129, 0.10); border: 1px solid rgba(16, 185, 129, 0.2);;">
                    <i class="fa fa-car-side fa-2x text-success"></i>
                </div>
                <div class="text-end">
                    <p class="mb-1 text-muted small fw-bold text-uppercase tracking-wider">Active Listings</p>
                    <h2 class="mb-0 font-monospace fw-bold text-white" style="font-size: 2.25rem;">@(ViewBag.TotalListings ?? 0)</h2>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="admin-card d-flex align-items-center justify-content-between p-4">
                <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px; background: rgba(245, 158, 11, 0.10); border: 1px solid rgba(245, 158, 11, 0.2);">
                    <i class="fa fa-book-atlas fa-2x text-warning"></i>
                </div>
                <div class="text-end">
                    <p class="mb-1 text-muted small fw-bold text-uppercase tracking-wider">Glossary Dictionary</p>
                    <h2 class="mb-0 font-monospace fw-bold text-white" style="font-size: 2.25rem;">@(ViewBag.TotalGlossaryTerms ?? 0)</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12 col-lg-8">
            <div class="admin-card p-0 overflow-hidden shadow-sm h-100">
                <div class="py-3 px-4 border-bottom d-flex justify-content-between align-items-center" style="background: rgba(0,0,0,0.15); border-color: var(--border-dim) !important;">
                    <h5 class="mb-0 text-white fw-bold">
                        <i class="fa fa-clock me-2 text-primary"></i>Recent Inventory Additions Queue
                    </h5>
                    <span class="badge badge-low small font-monospace">Live Pipeline Streams</span>
                </div>
                
                <div class="table-responsive">
                    <table class="table mb-0 table-hover align-middle w-100 custom-admin-table">
                        <thead>
                            <tr>
                                <th scope="col" style="width: 15%;" class="ps-4">Listing ID</th>
                                <th scope="col" style="width: 45%;">Vehicle Specification Meta</th>
                                <th scope="col" style="width: 15%;">Listing Price</th>
                                <th scope="col" style="width: 15%;">Creation Date</th>
                                <th scope="col" class="text-center" style="width: 10%;">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model == null || !Model.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">
                                        <i class="fa fa-folder-open fs-2 mb-3 d-block text-primary opacity-25"></i>
                                        No recent vehicle listings processed in the system logs yet.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                foreach (var listing in Model)
                                {
                                    <tr>
                                        <td class="ps-4 text-muted font-monospace fw-bold">#@listing.Id</td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="text-white fw-bold text-uppercase" style="letter-spacing: 0.02em;">@(listing.Car?.Make ?? "Unknown Make")</span>
                                                <span class="text-muted">@(listing.Car?.Model ?? "Model")</span>
                                                <span class="badge meta-year-badge ms-1">@(listing.Car?.Year ?? 0)</span>
                                            </div>
                                        </td>
                                        <td class="text-primary fw-bold font-monospace fs-5">
                                            @(listing.ListingPrice.HasValue ? listing.ListingPrice.Value.ToString("N0") : "0") <span class="small text-muted font-sans-serif" style="font-size: 0.75rem;">JOD</span>
                                        </td>
                                        <td class="text-muted small">@DateTime.Now.ToShortDateString()</td>
                                        <td class="text-center pe-4">
                                            @if (listing.Status == "Active")
                                            {
                                                <span class="badge badge-low d-block py-1.5 text-uppercase" style="font-size: 0.7rem; letter-spacing: 0.5px;">
                                                    Active
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-medium d-block py-1.5 text-uppercase" style="font-size: 0.7rem; letter-spacing: 0.5px;">
                                                    @listing.Status
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-4">
            <div class="admin-card h-100 p-4">
                <h5 class="fw-bold mb-2 text-white"><i class="fa-solid fa-gears me-2 text-primary"></i>Administrative Tools</h5>
                <p class="text-muted small mb-4">Direct action links to access critical platform configurations.</p>
                
                <div class="d-flex flex-column gap-3">
                    <a asp-area="Admin" asp-controller="Admin" asp-action="GlossaryManager" class="btn btn-outline-dark text-start p-3 w-100 hover-lift d-block text-decoration-none" style="border-color: var(--border-dim) !important;">
                        <div class="fw-bold text-white mb-1"><i class="fa-solid fa-book me-2 text-primary"></i>Glossary Terms Control (FR-7.4)</div>
                        <div class="text-muted small">Modify plain language explanations for the "White Card" (ورقة الفحص).</div>
                    </a>

                    <a asp-area="Admin" asp-controller="Admin" asp-action="UsersList" class="btn btn-outline-dark text-start p-3 w-100 hover-lift d-block text-decoration-none" style="border-color: var(--border-dim) !important;">
                        <div class="fw-bold text-white mb-1"><i class="fa-solid fa-users-gear me-2 text-primary"></i>User Accounts Directory (FR-7.1)</div>
                        <div class="text-muted small">View and audit all registered platform user accounts.</div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>