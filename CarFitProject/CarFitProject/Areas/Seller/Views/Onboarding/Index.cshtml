@model CarFitProject.ViewModel.DealerOnboardingViewModel
@{
    ViewData["Title"] = "Dealer Onboarding";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="bg-white shadow-sm rounded-4 p-5">
                <div class="text-center mb-4">
                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary px-3 py-2 rounded-pill fw-bold mb-3">DEALER ONBOARDING</span>
                    <h2 class="fw-bold text-dark mb-1">Tell us about your dealership</h2>
                    <p class="text-muted">We'll review your application before you can list vehicles.</p>
                </div>

                <form method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Name" class="form-control border-2" placeholder="Dealership name" />
                        <label asp-for="Name" class="fw-bold text-secondary">Dealership name</label>
                        <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Phone" class="form-control border-2" placeholder="Phone" autocomplete="tel" />
                        <label asp-for="Phone" class="fw-bold text-secondary">Phone</label>
                        <span asp-validation-for="Phone" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Email" class="form-control border-2" placeholder="name@example.com" autocomplete="email" />
                        <label asp-for="Email" class="fw-bold text-secondary">Contact email</label>
                        <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="City" class="form-control border-2" placeholder="City" />
                                <label asp-for="City" class="fw-bold text-secondary">City</label>
                                <span asp-validation-for="City" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="Neighborhood" class="form-control border-2" placeholder="Neighborhood" />
                                <label asp-for="Neighborhood" class="fw-bold text-secondary">Neighborhood</label>
                                <span asp-validation-for="Neighborhood" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="w-100 btn btn-lg btn-primary py-3 fw-bold">
                        <i class="fa-solid fa-paper-plane me-2"></i>Submit for review
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
