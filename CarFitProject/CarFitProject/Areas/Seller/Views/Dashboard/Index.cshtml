@model CarFitProject.Models.Seller
@{
    ViewData["Title"] = SharedLocalizer["Seller.Dashboard.Title"].Value;
}

<div class="container py-5">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success" role="alert">@TempData["SuccessMessage"]</div>
    }

    <div class="row mb-4">
        <div class="col-12">
            <div class="bg-white shadow-sm rounded-4 p-4 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                <div>
                    <h2 class="fw-bold text-dark mb-1">@string.Format(SharedLocalizer["Seller.Dashboard.Welcome"].Value, Model.Name)</h2>
                    <p class="text-muted mb-0">@Model.City@(string.IsNullOrEmpty(Model.Neighborhood) ? "" : " · " + Model.Neighborhood)</p>
                </div>
                <div class="text-md-end">
                    @if (Model.IsApproved)
                    {
                        <span class="badge bg-success bg-opacity-10 text-success border border-success px-3 py-2 rounded-pill fw-bold">
                            <i class="fa fa-check-circle me-1"></i>@SharedLocalizer["Seller.Approved"]
                            @if (!string.IsNullOrEmpty(Model.Tier))
                            {
                                <span class="ms-2 text-uppercase">@Model.Tier</span>
                            }
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-warning bg-opacity-10 text-warning border border-warning px-3 py-2 rounded-pill fw-bold">
                            <i class="fa fa-clock me-1"></i>@SharedLocalizer["Seller.Dashboard.PendingApproval"]
                        </span>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (!Model.IsApproved)
    {
        <div class="alert alert-info">
            <i class="fa fa-info-circle me-2"></i>
            @SharedLocalizer["Seller.Dashboard.PendingAlert"]
        </div>
    }

    <div class="row g-3">
        <div class="col-md-4">
            <div class="bg-white shadow-sm rounded-4 p-4 h-100">
                <h6 class="text-muted text-uppercase small fw-bold mb-2">@SharedLocalizer["Seller.Dashboard.Phone"]</h6>
                <div class="fw-semibold">@Model.Phone</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="bg-white shadow-sm rounded-4 p-4 h-100">
                <h6 class="text-muted text-uppercase small fw-bold mb-2">@SharedLocalizer["Seller.Dashboard.Email"]</h6>
                <div class="fw-semibold">@Model.Email</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="bg-white shadow-sm rounded-4 p-4 h-100 d-flex flex-column">
                <h6 class="text-muted text-uppercase small fw-bold mb-2">@SharedLocalizer["Seller.Dashboard.Inventory"]</h6>
                <a asp-area="Seller" asp-controller="Inventory" asp-action="Index" class="btn btn-outline-primary mt-auto">
                    <i class="fa fa-car me-2"></i>@SharedLocalizer["Seller.Dashboard.ManageListings"]
                </a>
            </div>
        </div>
    </div>
</div>
