@model IEnumerable<CarFitProject.Models.CarListing>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Dealership Stock Control";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-5 pb-3 border-bottom">
        <div>
            <span class="badge bg-success bg-opacity-10 text-success border border-success px-3 py-2 rounded-pill fw-bold mb-2">FR-3 SELLER MANAGEMENT WORKSPACE</span>
            <h1 class="fw-bold text-dark mb-0"><i class="fa-solid fa-boxes-stacked me-2 text-success"></i>Dealership Inventory Dashboard</h1>
            <p class="text-muted">Manage active listings, review inspections, and adjust marketplace valuations.</p>
        </div>
        <div>
            <a class="btn btn-primary btn-lg fw-bold px-4 shadow-sm" asp-action="AddCar">
                <i class="fa-solid fa-circle-plus me-2"></i>List New Vehicle
            </a>
        </div>
    </div>

    <div class="glass-card shadow-sm border-0 bg-white rounded-4 overflow-hidden p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 text-start">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">Vehicle Specs</th>
                        <th>Year</th>
                        <th>Market Price</th>
                        <th>Payment Options</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Lot Controls</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-car-burst fs-2 mb-3 d-block text-secondary"></i>
                                No inventory items listed yet on your profile lot. Click "List New Vehicle" to get started.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark fs-5">@item.Car?.Make @item.Car?.Model</div>
                                    <span class="text-muted small">ID Ref Code: #@item.CarId</span>
                                </td>
                                <td><span class="badge bg-light text-dark border p-2 fw-bold">@item.Car?.Year</span></td>
                                <td class="fw-bold text-primary">@(item.ListingPrice.HasValue ? item.ListingPrice.Value.ToString("N0") + " JD" : "Price on Request")</td>
                                <td>
                                    <span class="badge bg-info bg-opacity-10 text-info border border-info px-2.5 py-1.5 fw-bold">
                                        <i class="fa-solid fa-credit-card me-1"></i> @item.PaymentMethodAllowed
                                    </span>
                                </td>
                                <td>
                                    @if (item.Status == "Active")
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success px-2.5 py-1.5 fw-bold">Active</span>
                                    }
                                    else if (item.Status == "Pending")
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning border border-warning px-2.5 py-1.5 fw-bold">Pending Review</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary px-2.5 py-1.5 fw-bold">@item.Status</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <button class="btn btn-sm btn-outline-secondary me-1 fw-bold" onclick="alert('Manage Specifications console integration is available on production deployment.')">
                                        <i class="fa-solid fa-pen me-1"></i>Edit
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger fw-bold" onclick="alert('Listing suspension must be requested through admin moderation desk.')">
                                        <i class="fa-solid fa-trash me-1"></i>Delist
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>