@model List<CarFitProject.Models.CarListing>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Dealership Stock";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-5 border-bottom pb-3">
        <div>
            <span class="badge bg-success bg-opacity-10 text-success border border-success px-3 py-2 rounded-pill fw-bold mb-2">FR-3 SELLER MANAGEMENT WORKSPACE</span>
            <h1 class="fw-bold text-dark mb-0"><i class="fa-solid fa-warehouse me-2 text-success"></i>Dealership Stock Panel</h1>
            <p class="text-muted">Manage your asset directory and register official inspection metrics.</p>
        </div>
        <a asp-area="Seller" asp-controller="Inventory" asp-action="AddCar" class="btn btn-success btn-lg fw-bold px-4 shadow-sm">
            <i class="fa-solid fa-plus me-2"></i>List New Vehicle
        </a>
    </div>

    <div class="glass-card shadow-sm border-0 bg-white rounded-4 overflow-hidden p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 text-start">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">Vehicle Details</th>
                        <th>Year</th>
                        <th>Market Price</th>
                        <th>Inspection Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-car-tunnel fs-2 mb-3 d-block text-secondary"></i>
                                No listings currently registered on this dealer lot.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var listing in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark fs-5">@listing.Car?.Make @listing.Car?.Model</div>
                                    <small class="text-muted">Trim: @listing.Car?.Trim | Fuel: @listing.Car?.FuelType</small>
                                </td>
                                <td><span class="badge bg-light text-dark border p-2 fw-bold">@listing.Car?.Year</span></td>
                                <td class="text-success fw-bold">JD @listing.ListingPrice?.ToString("N0")</td>
                                <td>
                                    @if (listing.Car?.InspectionReport != null)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success px-2.5 py-1.5 fw-bold">
                                            <i class="fa-solid fa-circle-check me-1"></i>Report Attached
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning border border-warning px-2.5 py-1.5 fw-bold">
                                            <i class="fa-solid fa-circle-notch fa-spin me-1"></i>Pending Appraisal
                                        </span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-area="Seller" asp-controller="Inventory" asp-action="Index" class="btn btn-sm btn-outline-secondary me-1 fw-bold">
                                        <i class="fa-solid fa-sliders me-1"></i>Manage
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>