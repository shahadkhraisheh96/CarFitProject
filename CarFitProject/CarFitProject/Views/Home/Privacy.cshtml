@{
    ViewData["Title"] = Localizer["Privacy.Title"].Value;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="glass-card shadow-sm bg-white rounded-4 p-5">
                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary px-3 py-2 rounded-pill fw-bold mb-3">@Localizer["Privacy.Badge"]</span>
                <h1 class="fw-bold text-dark mb-4"><i class="fa-solid fa-user-shield me-2 text-primary"></i>@Localizer["Privacy.Title"]</h1>
                <hr class="mb-4">
                <p class="text-secondary leading-relaxed">
                    @Localizer["Privacy.Body1"]
                </p>
                <p class="text-secondary leading-relaxed mb-0">
                    @Localizer["Privacy.Body2"]
                </p>
            </div>
        </div>
    </div>
</div>
