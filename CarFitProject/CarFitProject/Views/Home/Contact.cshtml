@{
    ViewData["Title"] = Localizer["Contact.Title"].Value;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="page-hero mb-4">
        <div class="row align-items-center g-3">
            <div class="col-md-12 text-center">
                <span class="eyebrow"><i class="fa-solid fa-headset me-1"></i> Get in touch</span>
                <h1 class="mb-2">@Localizer["Contact.Title"]</h1>
                <p class="lead mb-0">We answer every message within one business day.</p>
                <nav aria-label="breadcrumb" class="mt-3">
                    <ol class="breadcrumb justify-content-center mb-0">
                        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-white-50 text-decoration-none">@Localizer["About.Crumb.Home"]</a></li>
                        <li class="breadcrumb-item text-white active" aria-current="page">@Localizer["Contact.Crumb"]</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>

<div class="container-xxl py-5">
    <div class="container">
        <div class="text-center mb-5">
            <span class="text-eyebrow d-block mb-2">@Localizer["Contact.Badge"]</span>
            <h1 class="fw-bold text-dark" style="letter-spacing:-0.03em;">@Localizer["Contact.Heading"]</h1>
            <p class="cf-subtitle">@Localizer["Contact.Tagline"]</p>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="stat-card">
                    <div class="stat-icon"><i class="fa-solid fa-phone"></i></div>
                    <div>
                        <div class="stat-label">Phone</div>
                        <div class="fw-bold text-dark">+962 6 000 0000</div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card stat-info">
                    <div class="stat-icon"><i class="fa-solid fa-envelope"></i></div>
                    <div>
                        <div class="stat-label">Email</div>
                        <div class="fw-bold text-dark">hello@carfit.jo</div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card stat-success">
                    <div class="stat-icon"><i class="fa-solid fa-location-dot"></i></div>
                    <div>
                        <div class="stat-label">Office</div>
                        <div class="fw-bold text-dark">Amman, Jordan</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-6">
                <div class="rounded-4 overflow-hidden shadow-sm hover-lift h-100">
                    <iframe class="w-100 h-100"
                            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d108215.44111328904!2d35.83471460591242!3d31.951569421833192!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x151b14e995b0541b%3A0xc4eb090bda332463!2sAmman!5e0!3m2!1sen!2sjo!4v1716000000000!5m2!1sen!2sjo"
                            frameborder="0" style="min-height: 460px; border:0;" allowfullscreen="" aria-hidden="false"
                            tabindex="0"></iframe>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-section-card h-100" style="max-width:none;">
                    <div class="section-heading">
                        <h3>Send us a message</h3>
                    </div>
                    <p class="cf-subtitle mb-4">@Localizer["Contact.Body"]</p>
                    <form method="post" action="#">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="form-floating cf-floating">
                                    <input type="text" class="form-control" id="name" placeholder=" ">
                                    <label for="name">@Localizer["Contact.Field.Name"]</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating cf-floating">
                                    <input type="email" class="form-control" id="email" placeholder=" ">
                                    <label for="email">@Localizer["Contact.Field.Email"]</label>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-floating cf-floating">
                                    <input type="text" class="form-control" id="subject" placeholder=" ">
                                    <label for="subject">@Localizer["Contact.Field.Subject"]</label>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-floating cf-floating">
                                    <textarea class="form-control" placeholder=" " id="message" style="height: 150px"></textarea>
                                    <label for="message">@Localizer["Contact.Field.Message"]</label>
                                </div>
                            </div>
                            <div class="col-12">
                                <button class="btn btn-primary w-100 fw-bold" type="submit"><i class="fa-solid fa-paper-plane me-2"></i>@Localizer["Contact.Send"]</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container py-4">
    <div class="section-heading">
        <h2>Frequently asked</h2>
    </div>
    <p class="cf-subtitle mb-4">Quick answers before you reach out.</p>
    <div class="row g-3">
        <div class="col-md-6">
            <div class="form-section-card h-100" style="max-width:none;">
                <div class="d-flex align-items-start gap-3">
                    <div class="persona-avatar" style="width:44px;height:44px;border-radius:12px;font-size:1rem;background:rgba(216,19,36,0.10);color:var(--primary);"><i class="fa-solid fa-clipboard-check"></i></div>
                    <div>
                        <h5 class="fw-bold mb-1">How does the inspection work?</h5>
                        <p class="text-muted small mb-0">Book online, a CarFit specialist meets you at the dealer's lot, runs a 150-point check, and you get the report on the same day.</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-section-card h-100" style="max-width:none;">
                <div class="d-flex align-items-start gap-3">
                    <div class="persona-avatar" style="width:44px;height:44px;border-radius:12px;font-size:1rem;background:rgba(6,182,212,0.12);color:var(--info);"><i class="fa-solid fa-circle-question"></i></div>
                    <div>
                        <h5 class="fw-bold mb-1">Is the questionnaire required?</h5>
                        <p class="text-muted small mb-0">No — you can browse all listings without signing in. The questionnaire only powers the personalised "Recommended for you" matches.</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-section-card h-100" style="max-width:none;">
                <div class="d-flex align-items-start gap-3">
                    <div class="persona-avatar" style="width:44px;height:44px;border-radius:12px;font-size:1rem;background:rgba(16,185,129,0.12);color:var(--success);"><i class="fa-solid fa-building"></i></div>
                    <div>
                        <h5 class="fw-bold mb-1">I'm a dealer — how do I list?</h5>
                        <p class="text-muted small mb-0">Register as a Dealer, fill the onboarding form, and once approved you can publish unlimited listings from the Seller Lot.</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-section-card h-100" style="max-width:none;">
                <div class="d-flex align-items-start gap-3">
                    <div class="persona-avatar" style="width:44px;height:44px;border-radius:12px;font-size:1rem;background:rgba(245,158,11,0.14);color:var(--warning);"><i class="fa-solid fa-clock"></i></div>
                    <div>
                        <h5 class="fw-bold mb-1">Office hours</h5>
                        <p class="text-muted small mb-0">Sunday – Thursday, 9:00 AM to 6:00 PM (Amman time). Closed on public holidays. Email is monitored on weekends.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
