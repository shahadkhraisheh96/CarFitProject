@model CarFitProject.ViewModel.InspectionBookingViewModel
@{
    ViewData["Title"] = "Book Inspection Report";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Page Header Start -->
<div class="container-fluid page-header mb-5 p-0" style="background-image: url('/img/carousel-bg-2.jpg');">
    <div class="container-fluid page-header-inner py-5">
        <div class="container text-center">
            <h1 class="display-3 text-white mb-3 animated slideInDown">Schedule Appraisals</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb justify-content-center text-uppercase">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                    <li class="breadcrumb-item text-white active" aria-current="page">Booking Gateway</li>
                </ol>
            </nav>
        </div>
    </div>
</div>
<!-- Page Header End -->

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 shadow-sm p-4 mb-5" role="alert" style="background: rgba(16, 185, 129, 0.15); border-left: 5px solid var(--success) !important;">
                    <div class="d-flex align-items-center">
                        <i class="fa-solid fa-circle-check text-success fs-3 me-3"></i>
                        <div>
                            <h5 class="alert-heading fw-bold text-success mb-1">Success!</h5>
                            <p class="mb-0 text-secondary">@TempData["SuccessMessage"]</p>
                        </div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="glass-card shadow-lg border-0 bg-white rounded-4 overflow-hidden p-5">
                <div class="text-center mb-5">
                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary px-3 py-2 rounded-pill fw-bold mb-3">FR-6 BOOKING ENGINE</span>
                    <h2 class="fw-bold text-dark mb-1">Verify Your Next Vehicle Purchase</h2>
                    <p class="text-muted">Schedule a detailed mobile inspection at the dealer's lot in Jordan.</p>
                </div>

                <form asp-controller="Inspection" asp-action="Book" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-4" role="alert"></div>

                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="CustomerName" class="form-label fw-bold text-secondary">Your Name</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-2 border-end-0"><i class="fa-solid fa-user text-muted"></i></span>
                                    <input asp-for="CustomerName" class="form-control border-2 border-start-0" placeholder="e.g. Ahmad Al-Saeed" />
                                </div>
                                <span class="text-danger small mt-1 d-block" asp-validation-for="CustomerName"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="CustomerEmail" class="form-label fw-bold text-secondary">Email Address</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-2 border-end-0"><i class="fa-solid fa-envelope text-muted"></i></span>
                                    <input asp-for="CustomerEmail" type="email" class="form-control border-2 border-start-0" placeholder="name@example.com" />
                                </div>
                                <span class="text-danger small mt-1 d-block" asp-validation-for="CustomerEmail"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="PackageType" class="form-label fw-bold text-secondary">Inspection Package</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-2 border-end-0"><i class="fa-solid fa-gears text-muted"></i></span>
                                    <select asp-for="PackageType" class="form-select border-2 border-start-0">
                                        <option value="">Select Package Tier</option>
                                        <option value="Powertrain Scan">01. Powertrain & ECU Scanner (JD 35)</option>
                                        <option value="Chassis Sound Integrity">02. Undercarriage & Chassis Alignment (JD 50)</option>
                                        <option value="Complete Baseline">03. All-Inclusive Ultimate Verification (JD 75)</option>
                                    </select>
                                </div>
                                <span class="text-danger small mt-1 d-block" asp-validation-for="PackageType"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="PreferredDate" class="form-label fw-bold text-secondary">Preferred Inspection Date</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-2 border-end-0"><i class="fa-solid fa-calendar-days text-muted"></i></span>
                                    <input asp-for="PreferredDate" type="date" class="form-control border-2 border-start-0" />
                                </div>
                                <span class="text-danger small mt-1 d-block" asp-validation-for="PreferredDate"></span>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="form-group">
                                <label asp-for="VehicleNotes" class="form-label fw-bold text-secondary">Vehicle Details & Location Notes</label>
                                <textarea asp-for="VehicleNotes" class="form-control border-2" rows="4" placeholder="Mention Make, Model, Year, Seller Location, or specific areas of concern..."></textarea>
                                <span class="text-danger small mt-1 d-block" asp-validation-for="VehicleNotes"></span>
                            </div>
                        </div>

                        <div class="col-12 text-center pt-3">
                            <button type="submit" class="btn btn-primary w-100 py-3 fw-bold"><i class="fa-solid fa-check-double me-2"></i>Schedule Verification Session</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
