@{
    ViewData["Title"] = Localizer["Inspection.Title"].Value;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid page-header mb-5 p-0" style="background-image: url('/img/carousel-bg-2.jpg');">
    <div class="container-fluid page-header-inner py-5">
        <div class="container text-center">
            <h1 class="display-3 text-white mb-3 animated slideInDown">@Localizer["Inspection.Title"]</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb justify-content-center text-uppercase">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-white-50">@Localizer["About.Crumb.Home"]</a></li>
                    <li class="breadcrumb-item text-white active" aria-current="page">@Localizer["Inspection.Crumb"]</li>
                </ol>
            </nav>
        </div>
    </div>
</div>

<div class="container-xxl py-5">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary px-3 py-2 rounded-pill fw-bold mb-2">@Localizer["Inspection.Badge"]</span>
            <h1 class="fw-bold text-dark">@Localizer["Inspection.Heading"]</h1>
            <p class="text-muted">@Localizer["Inspection.Tagline"]</p>
        </div>
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="nav w-100 nav-pills me-4 d-flex flex-column gap-3">
                    <button class="nav-link w-100 d-flex align-items-center text-start p-4 active border-2" data-bs-toggle="pill" data-bs-target="#tab-pane-1" type="button" style="border-radius:16px;">
                        <i class="fa-solid fa-car-battery fs-3 me-3 text-primary"></i>
                        <h5 class="m-0 text-dark">@Localizer["Inspection.Tab1"]</h5>
                    </button>
                    <button class="nav-link w-100 d-flex align-items-center text-start p-4 border-2" data-bs-toggle="pill" data-bs-target="#tab-pane-2" type="button" style="border-radius:16px;">
                        <i class="fa-solid fa-car-burst fs-3 me-3 text-primary"></i>
                        <h5 class="m-0 text-dark">@Localizer["Inspection.Tab2"]</h5>
                    </button>
                    <button class="nav-link w-100 d-flex align-items-center text-start p-4 border-2" data-bs-toggle="pill" data-bs-target="#tab-pane-3" type="button" style="border-radius:16px;">
                        <i class="fa-solid fa-magnifying-glass-chart fs-3 me-3 text-primary"></i>
                        <h5 class="m-0 text-dark">@Localizer["Inspection.Tab3"]</h5>
                    </button>
                </div>
            </div>
            <div class="col-lg-8">
                <div class="tab-content w-100">
                    <div class="tab-pane fade show active" id="tab-pane-1">
                        <div class="glass-card bg-white p-5 border-0">
                            <div class="row g-4 align-items-center">
                                <div class="col-md-5" style="min-height: 250px;">
                                    <div class="position-relative h-100 rounded-3 overflow-hidden shadow-sm">
                                        <img class="img-fluid w-100 h-100" src="/img/service-1.jpg" style="object-fit: cover;" alt="">
                                    </div>
                                </div>
                                <div class="col-md-7">
                                    <h3 class="fw-bold mb-3 text-dark">@Localizer["Inspection.Tab1.Heading"]</h3>
                                    <p class="text-muted small mb-4">@Localizer["Inspection.Tab1.Body"]</p>
                                    <div class="d-flex flex-column gap-2 mb-4">
                                        <div class="d-flex align-items-center text-secondary small"><i class="fa-solid fa-circle-check text-success me-2"></i>@Localizer["Inspection.Tab1.B1"]</div>
                                        <div class="d-flex align-items-center text-secondary small"><i class="fa-solid fa-circle-check text-success me-2"></i>@Localizer["Inspection.Tab1.B2"]</div>
                                        <div class="d-flex align-items-center text-secondary small"><i class="fa-solid fa-circle-check text-success me-2"></i>@Localizer["Inspection.Tab1.B3"]</div>
                                    </div>
                                    <a asp-controller="Inspection" asp-action="Book" class="btn btn-primary w-100 py-3 fw-bold">@Localizer["Inspection.BookBtn"]</a>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="tab-pane fade" id="tab-pane-2">
                        <div class="glass-card bg-white p-5 border-0">
                            <div class="row g-4 align-items-center">
                                <div class="col-md-5" style="min-height: 250px;">
                                    <div class="position-relative h-100 rounded-3 overflow-hidden shadow-sm">
                                        <img class="img-fluid w-100 h-100" src="/img/service-2.jpg" style="object-fit: cover;" alt="">
                                    </div>
                                </div>
                                <div class="col-md-7">
                                    <h3 class="fw-bold mb-3 text-dark">@Localizer["Inspection.Tab2.Heading"]</h3>
                                    <p class="text-muted small mb-4">@Localizer["Inspection.Tab2.Body"]</p>
                                    <div class="d-flex flex-column gap-2 mb-4">
                                        <div class="d-flex align-items-center text-secondary small"><i class="fa-solid fa-circle-check text-success me-2"></i>@Localizer["Inspection.Tab2.B1"]</div>
                                        <div class="d-flex align-items-center text-secondary small"><i class="fa-solid fa-circle-check text-success me-2"></i>@Localizer["Inspection.Tab2.B2"]</div>
                                        <div class="d-flex align-items-center text-secondary small"><i class="fa-solid fa-circle-check text-success me-2"></i>@Localizer["Inspection.Tab2.B3"]</div>
                                    </div>
                                    <a asp-controller="Inspection" asp-action="Book" class="btn btn-primary w-100 py-3 fw-bold">@Localizer["Inspection.BookBtn"]</a>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="tab-pane fade" id="tab-pane-3">
                        <div class="glass-card bg-white p-5 border-0">
                            <div class="row g-4 align-items-center">
                                <div class="col-md-5" style="min-height: 250px;">
                                    <div class="position-relative h-100 rounded-3 overflow-hidden shadow-sm">
                                        <img class="img-fluid w-100 h-100" src="/img/service-3.jpg" style="object-fit: cover;" alt="">
                                    </div>
                                </div>
                                <div class="col-md-7">
                                    <h3 class="fw-bold mb-3 text-dark">@Localizer["Inspection.Tab3.Heading"]</h3>
                                    <p class="text-muted small mb-4">@Localizer["Inspection.Tab3.Body"]</p>
                                    <div class="d-flex flex-column gap-2 mb-4">
                                        <div class="d-flex align-items-center text-secondary small"><i class="fa-solid fa-circle-check text-success me-2"></i>@Localizer["Inspection.Tab3.B1"]</div>
                                        <div class="d-flex align-items-center text-secondary small"><i class="fa-solid fa-circle-check text-success me-2"></i>@Localizer["Inspection.Tab3.B2"]</div>
                                        <div class="d-flex align-items-center text-secondary small"><i class="fa-solid fa-circle-check text-success me-2"></i>@Localizer["Inspection.Tab3.B3"]</div>
                                    </div>
                                    <a asp-controller="Inspection" asp-action="Book" class="btn btn-primary w-100 py-3 fw-bold">@Localizer["Inspection.BookBtn"]</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
