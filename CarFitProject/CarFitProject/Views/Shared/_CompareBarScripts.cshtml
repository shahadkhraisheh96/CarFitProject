@*
    Client-side state for the compare drawer. Stores up to 3 listing IDs in
    sessionStorage and syncs UI: every .compare-toggle element toggles a
    listing in/out of the selection; the bar shows the current count.
    The "Compare" CTA links to /Buyer/Compare?ids=1,2,3.
*@
<script>
    (function () {
        var KEY = 'carfit.compare';
        var MAX = 3;

        function load() {
            try {
                var raw = sessionStorage.getItem(KEY);
                if (!raw) return [];
                var arr = JSON.parse(raw);
                return Array.isArray(arr) ? arr : [];
            } catch (_) { return []; }
        }
        function save(arr) {
            sessionStorage.setItem(KEY, JSON.stringify(arr));
        }
        function render() {
            var ids = load();
            var bar = document.getElementById('compareBar');
            var summary = document.getElementById('compareBarSummary');
            var go = document.getElementById('compareBarGo');
            if (!bar) return;

            if (ids.length === 0) {
                bar.classList.add('d-none');
            } else {
                bar.classList.remove('d-none');
                summary.textContent = ids.length + ' / ' + MAX + ' listings selected.';
                if (go) {
                    if (ids.length >= 2) {
                        go.classList.remove('disabled');
                        go.href = '/Buyer/Compare?ids=' + ids.join(',');
                    } else {
                        go.classList.add('disabled');
                        go.href = '#';
                    }
                }
            }

            document.querySelectorAll('.compare-toggle').forEach(function (btn) {
                var id = parseInt(btn.getAttribute('data-listing-id'), 10);
                var inList = ids.indexOf(id) >= 0;
                btn.classList.toggle('active', inList);
                btn.classList.toggle('btn-secondary', inList);
                btn.classList.toggle('btn-outline-secondary', !inList);
                btn.setAttribute('aria-pressed', inList ? 'true' : 'false');
            });
        }
        function toggle(id) {
            var ids = load();
            var idx = ids.indexOf(id);
            if (idx >= 0) {
                ids.splice(idx, 1);
            } else {
                if (ids.length >= MAX) {
                    alert('You can compare at most ' + MAX + ' cars at a time.');
                    return;
                }
                ids.push(id);
            }
            save(ids);
            render();
        }

        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.compare-toggle');
            if (btn) {
                e.preventDefault();
                var id = parseInt(btn.getAttribute('data-listing-id'), 10);
                if (id) toggle(id);
                return;
            }
            if (e.target.closest('#compareBarClear')) {
                sessionStorage.removeItem(KEY);
                render();
            }
        });

        render();
    })();
</script>
