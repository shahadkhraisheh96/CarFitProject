<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CarFit</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CarFitProject.styles.css" asp-append-version="true" />
    <link href="~/css/style.css" rel="stylesheet" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light sticky-top py-2 px-4">
            <a asp-controller="Home" asp-action="Index" class="navbar-brand d-flex align-items-center">
                <h2 class="m-0"><i class="fa-solid fa-car-burst me-2"></i>CarFit</h2>
            </a>
            <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarCollapse">
                <div class="navbar-nav ms-auto py-3 py-lg-0">
                    <a asp-controller="Home" asp-action="Index" class="nav-item nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" && ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")">Home</a>
                    
                    <a asp-area="" asp-controller="Inventory" asp-action="Search" class="nav-item nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Inventory" && ViewContext.RouteData.Values["Action"]?.ToString() == "Search" ? "active" : "") fw-semibold">Explore Inventory</a>

                    <a asp-controller="Home" asp-action="About" class="nav-item nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "About" ? "active" : "")">About Advisor</a>
                    <a asp-controller="Inspection" asp-action="Index" class="nav-item nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Inspection" ? "active" : "")">Inspection Modules</a>
                    <a asp-controller="Home" asp-action="Contact" class="nav-item nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Contact" ? "active" : "")">Contact</a>

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        if (User.IsInRole("Admin"))
                        {
                            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="nav-item nav-link fw-bold text-danger"><i class="fa-solid fa-shield-halved me-1"></i> Admin Base</a>
                        }
                        else if (User.IsInRole("Seller"))
                        {
                            <a asp-area="Seller" asp-controller="Inventory" asp-action="Index" class="nav-item nav-link fw-bold text-success"><i class="fa-solid fa-building me-1"></i> Seller Lot</a>
                        }
                        else if (User.IsInRole("Buyer"))
                        {
                            <a asp-area="Buyer" asp-controller="Dashboard" asp-action="Index" class="nav-item nav-link fw-bold text-primary"><i class="fa-solid fa-user-gear me-1"></i> Buyer Hub</a>
                        }

                        <form class="form-inline d-flex align-items-center px-3" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post" id="navLogoutForm">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="nav-item nav-link border-0 bg-transparent text-uppercase fw-semibold text-secondary" style="cursor:pointer;"><i class="fa-solid fa-right-from-bracket me-1"></i>Logout</button>
                        </form>
                    }
                    else
                    {
                        <a asp-area="Identity" asp-page="/Account/Login" class="nav-item nav-link fw-bold">Login</a>
                        <a asp-area="Identity" asp-page="/Account/Register" class="nav-item nav-link fw-bold text-primary">Register</a>
                    }
                </div>

                @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Buyer"))
                {
                    <a asp-area="Buyer" asp-controller="Dashboard" asp-action="Index" class="btn btn-primary py-2 px-4 d-none d-lg-block">View My Fits <i class="fa fa-arrow-right ms-2"></i></a>
                }
                else
                {
                    <a asp-controller="Inspection" asp-action="Book" class="btn btn-primary py-2 px-4 d-none d-lg-block">Get Inspection Report <i class="fa fa-arrow-right ms-2"></i></a>
                }
            </div>
        </nav>
    </header>
    <div class="container my-4">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-white py-3 mt-auto">
        <div class="container text-center">
            &copy; @DateTime.Now.Year - CarFit - <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-primary">Privacy Policy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>