@model CarFitProject.ViewModel.PagerViewModel
@{
    if (Model.TotalPages <= 1) { return; }
    var isRtl = System.Globalization.CultureInfo.CurrentUICulture.TextInfo.IsRightToLeft;
    var prevIcon = isRtl ? "fa-chevron-right" : "fa-chevron-left";
    var nextIcon = isRtl ? "fa-chevron-left" : "fa-chevron-right";
    var baseDict = new Microsoft.AspNetCore.Routing.RouteValueDictionary(Model.RouteValues ?? new { });
    Dictionary<string, string> For(int p)
    {
        var d = new Dictionary<string, string>();
        foreach (var kv in baseDict)
        {
            if (kv.Value != null)
            {
                var s = kv.Value.ToString();
                if (!string.IsNullOrEmpty(s)) d[kv.Key] = s;
            }
        }
        d["page"] = p.ToString();
        return d;
    }
}

<nav class="mt-4">
    <ul class="pagination justify-content-center mb-0">
        <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
            <a class="page-link" asp-action="@Model.Action" asp-controller="@Model.Controller" asp-all-route-data="@For(Math.Max(1, Model.Page - 1))">
                <i class="fa @prevIcon"></i>
            </a>
        </li>
        @for (var p = 1; p <= Model.TotalPages; p++)
        {
            <li class="page-item @(p == Model.Page ? "active" : "")">
                <a class="page-link" asp-action="@Model.Action" asp-controller="@Model.Controller" asp-all-route-data="@For(p)">@p</a>
            </li>
        }
        <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
            <a class="page-link" asp-action="@Model.Action" asp-controller="@Model.Controller" asp-all-route-data="@For(Math.Min(Model.TotalPages, Model.Page + 1))">
                <i class="fa @nextIcon"></i>
            </a>
        </li>
    </ul>
</nav>
