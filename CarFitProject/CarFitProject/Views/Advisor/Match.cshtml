@model IEnumerable<CarFitProject.ViewModel.RecommendedCarViewModel>

@{
    ViewData["Title"] = "Your Smart Matches";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Page Header Start -->
<div class="container-fluid page-header mb-5 p-0" style="background-image: url('/img/carousel-bg-1.jpg');">
    <div class="container-fluid page-header-inner py-5">
        <div class="container text-center">
            <h1 class="display-3 text-white mb-3 animated slideInDown">Your Smart Matches</h1>
            <span class="badge bg-primary bg-opacity-25 text-white border border-primary px-3 py-2 rounded-pill fw-bold">// Tailored Persona Profile: @ViewBag.UserProfileName //</span>
        </div>
    </div>
</div>
<!-- Page Header End -->

<div class="container-xxl py-5">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary px-3 py-2 rounded-pill fw-bold mb-2">AI MATCHMAKING ENGINE</span>
            <h1 class="fw-bold text-dark">Recommended Vehicles Matching Your Lifestyle</h1>
            <p class="text-muted">Analyzed using 150 points of diagnostic alignment.</p>
        </div>

        @if (Model == null || !Model.Any())
        {
            <div class="glass-card text-center py-5 bg-white border-0">
                <i class="fa-solid fa-car-tunnel text-secondary fs-1 mb-3"></i>
                <h5 class="fw-bold text-dark">No high-compatibility vehicle matches found.</h5>
                <p class="text-muted mb-4">Try expanding your budget parameters or modifying size constraints inside your driver dashboard profile settings.</p>
                <a asp-area="Buyer" asp-controller="Dashboard" asp-action="CreateProfile" class="btn btn-primary px-5 py-3 fw-bold">Modify Questionnaire</a>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var item in Model)
                {
                    <div class="col-lg-4 col-md-6">
                        <div class="glass-card h-100 hover-lift bg-white p-0 border-0 overflow-hidden position-relative shadow-sm d-flex flex-column">
                            
                            <div class="position-absolute top-0 start-0 m-3 z-index-2">
                                <span class="badge badge-match">
                                    <i class="fa-solid fa-bolt me-1"></i> @item.DynamicMatchScore% Fit
                                </span>
                            </div>

                            <div class="bg-dark text-white p-4 pt-5" style="background: linear-gradient(135deg, var(--secondary) 0%, var(--secondary-light) 100%);">
                                <span class="text-white-50 text-uppercase tracking-wider small fw-bold"><i class="fa-solid fa-location-dot me-1"></i> @item.City</span>
                                <h3 class="fw-bold mb-0 text-white text-truncate mt-1">@item.Make @item.Model</h3>
                                <p class="text-white-50 small mb-0 mt-1"><i class="fa-solid fa-calendar me-1"></i>Year Model: @item.Year</p>
                            </div>

                            <div class="p-4 d-flex flex-column flex-grow-1 justify-content-between">
                                <table class="table table-sm table-borderless my-3 small text-secondary">
                                    <tbody>
                                        <tr>
                                            <td class="ps-0"><i class="fa-solid fa-screwdriver-wrench me-2 text-primary"></i>Body Specs:</td>
                                            <td class="fw-bold text-dark text-end text-truncate" style="max-width: 150px;">@item.BodyCondition</td>
                                        </tr>
                                        <tr>
                                            <td class="ps-0"><i class="fa-solid fa-circle-check me-2 text-primary"></i>Engine Trust:</td>
                                            <td class="fw-bold text-success text-end">@item.TrustScore.ToString("P0")</td>
                                        </tr>
                                    </tbody>
                                </table>

                                <hr class="border-secondary border-opacity-10 my-3">

                                <div class="d-flex align-items-center justify-content-between pt-2">
                                    <div>
                                        <span class="text-muted d-block small">Listing Price:</span>
                                        <span class="fs-4 fw-bold text-primary">@item.ListingPrice.ToString("N0") <span class="fs-6 fw-normal text-secondary">JD</span></span>
                                    </div>
                                    <a asp-controller="Inspection" asp-action="Book" asp-route-notes="Inquiring about matched @item.Make @item.Model (@item.Year)" class="btn btn-secondary py-2.5 px-4 small">
                                        Inspect Car <i class="fa-solid fa-arrow-right ms-2 small"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>